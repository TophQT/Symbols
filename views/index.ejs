    <!-- Our Customers Section -->
    <section id="our-customers" class="py-24 relative overflow-hidden bg-tech-dark border-t border-white/5">
        <!-- Background Decor -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-tech-blue/5 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-tech-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

        <div class="container mx-auto px-6 relative z-10">
            <div class="text-center mb-16 space-y-4 reveal">
                <h2 class="text-4xl md:text-5xl font-bold font-grotesk text-white leading-tight">Our <span class="text-transparent bg-clip-text bg-gradient-to-r from-tech-blue to-tech-accent">Valued</span> Customers</h2>
                <div class="w-20 h-1 bg-tech-blue mx-auto rounded-full"></div>
                <p class="text-white/60 max-w-2xl mx-auto text-lg leading-relaxed">Trusted by industry leaders across various sectors to deliver precision and efficiency through innovative technology.</p>
            </div>

            <!-- Filter Buttons -->
            <div class="flex flex-wrap justify-center gap-3 mb-16">
                <button type="button" data-filter="all" class="customer-filter-btn active px-6 py-2 rounded-full text-sm font-bold transition-all duration-300 bg-tech-blue text-white border border-tech-blue cursor-pointer z-20">All</button>
                <% const filterCategories = ['Manufacturing', 'Retail', 'Construction', 'Banking', 'Transportation & Logistics', 'Health Care', 'Distribution', 'Agriculture', 'Others']; %>
                <% filterCategories.forEach(cat => { %>
                    <button type="button" data-filter="<%= cat %>" class="customer-filter-btn px-6 py-2 rounded-full text-sm font-bold transition-all duration-300 text-white/60 bg-white/5 border border-white/10 hover:border-tech-blue hover:text-white cursor-pointer z-20"><%= cat %></button>
                <% }) %>
            </div>

            <!-- Customers Grid -->
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-8 reveal" id="customers-grid">
                <% if (customers && customers.length > 0) { %>
                    <% customers.forEach(customer => { %>
                        <div class="customer-item group relative glass-card p-6 rounded-2xl flex items-center justify-center aspect-square transition-all duration-500 hover:scale-110 hover:border-tech-blue/30 hover:shadow-lg hover:shadow-tech-blue/20" data-category="<%= customer.category %>">
                            <img src="/uploads/customers/<%= customer.logo %>" alt="Customer Logo" class="max-w-full max-h-full object-contain transition-all duration-500 opacity-90 group-hover:opacity-100">
                            <!-- Tooltip/Badge -->
                            <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 px-3 py-1 bg-tech-blue text-[10px] font-bold text-white rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap">
                                <%= customer.category %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-20 glass-card rounded-3xl border-dashed">
                        <i data-lucide="users" class="w-12 h-12 text-white/20 mx-auto mb-4"></i>
                        <p class="text-white/40 font-medium">Join our growing list of satisfied customers.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<!-- Three.js Scene Setup -->
<script type="module">
    import * as THREE from 'three';
    import { FontLoader } from 'three/addons/loaders/FontLoader.js';
    import { TextGeometry } from 'three/addons/geometries/TextGeometry.js';

    // Hero Section Three.js
    const heroContainer = document.getElementById('hero-canvas');
    if (heroContainer) {
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        heroContainer.appendChild(renderer.domElement);

        // Barcode Object (Group of boxes)
        const barcodeGroup = new THREE.Group();
        const colors = [0x3b82f6, 0x00f2ff, 0x1e293b];
        
        // More realistic barcode pattern
        const barWidths = [0.05, 0.1, 0.05, 0.2, 0.1, 0.05, 0.15, 0.05, 0.1, 0.2, 0.05, 0.1];
        let currentX = -4;
        
        for (let i = 0; i < 50; i++) {
            const width = barWidths[i % barWidths.length];
            const height = 3.5; // Consistent height for barcode look
            const geometry = new THREE.BoxGeometry(width, height, 0.1);
            const material = new THREE.MeshStandardMaterial({ 
                color: colors[i % 2 === 0 ? 0 : 2],
                emissive: colors[i % 2 === 0 ? 0 : 2],
                emissiveIntensity: 0.3,
                transparent: true,
                opacity: 0.9
            });
            const mesh = new THREE.Mesh(geometry, material);
            mesh.position.x = currentX;
            currentX += width + 0.08;
            barcodeGroup.add(mesh);
        }
        scene.add(barcodeGroup);

        // Laser Scanner (Glowing effect - Horizontal line for Up/Down scan)
        const laserGeo = new THREE.BoxGeometry(9, 0.05, 0.5);
        const laserMat = new THREE.MeshBasicMaterial({ 
            color: 0xef4444,
            transparent: true,
            opacity: 0.8
        });
        const laser = new THREE.Mesh(laserGeo, laserMat);
        scene.add(laser);

        // Add a glow to the laser
        const glowGeo = new THREE.BoxGeometry(9, 0.2, 0.4);
        const glowMat = new THREE.MeshBasicMaterial({ 
            color: 0xef4444,
            transparent: true,
            opacity: 0.3
        });
        const glow = new THREE.Mesh(glowGeo, glowMat);
        laser.add(glow);

        // Lights
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
        scene.add(ambientLight);
        const pointLight = new THREE.PointLight(0x3b82f6, 3, 15);
        pointLight.position.set(2, 2, 5);
        scene.add(pointLight);

        camera.position.z = 6;
         camera.position.y = 0;
         camera.position.x = -2; // Shift camera left to move animation right

        // Animation Loop
        const animate = () => {
            requestAnimationFrame(animate);
            
            // Subtle movement for the barcode
            barcodeGroup.rotation.y = Math.sin(Date.now() * 0.0005) * 0.2;
            barcodeGroup.position.z = Math.cos(Date.now() * 0.0005) * 0.5;
            
            // Vertical laser scan (Up and Down)
            const time = Date.now() * 0.0015;
            laser.position.y = Math.sin(time) * 2;
            laser.position.z = 0.5;
            
            // Make bars pulse when laser passes vertically
            barcodeGroup.children.forEach(bar => {
                const distance = Math.abs(bar.position.y - laser.position.y);
                if (distance < 0.5) {
                    bar.material.emissiveIntensity = 1.5;
                } else {
                    bar.material.emissiveIntensity = 0.3;
                }
            });
            
            renderer.render(scene, camera);
        };
        // Responsive Resize logic with multiple breakpoints
        const handleResize = () => {
            const width = window.innerWidth;
            const height = window.innerHeight;

            renderer.setSize(width, height);
            camera.aspect = width / height;

            if (width < 1024) { // Mobile and Tablet devices
                heroContainer.style.display = 'none'; // Hide canvas
            } else {
                heroContainer.style.display = 'block'; // Show canvas

                if (width >= 1280) { // Large desktops
                    camera.position.z = 7;
                    camera.position.x = -4; // Furthest right
                    barcodeGroup.scale.set(1.0, 1.0, 1.0);
                    laser.scale.set(1.0, 1.0, 1.0);
                } else { // Laptops
                    camera.position.z = 8;
                    camera.position.x = -3; // Mid-right
                    barcodeGroup.scale.set(0.9, 0.9, 0.9);
                    laser.scale.set(0.9, 0.9, 0.9);
                }
            }

            camera.updateProjectionMatrix();
        };

        window.addEventListener('resize', handleResize);
        handleResize(); // Initial call to set size and position

        animate();
    }

    // Consulting Section Animation
    const consultContainer = document.getElementById('consulting-canvas');
    if (consultContainer) {
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, consultContainer.clientWidth / consultContainer.clientHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
        renderer.setSize(consultContainer.clientWidth, consultContainer.clientHeight);
        consultContainer.appendChild(renderer.domElement);

        const geometry = new THREE.IcosahedronGeometry(2, 1);
        const material = new THREE.MeshStandardMaterial({ 
            color: 0x3b82f6, 
            wireframe: true,
            transparent: true,
            opacity: 0.3
        });
        const sphere = new THREE.Mesh(geometry, material);
        scene.add(sphere);

        const light = new THREE.PointLight(0x3b82f6, 1, 10);
        light.position.set(5, 5, 5);
        scene.add(light);
        scene.add(new THREE.AmbientLight(0xffffff, 0.5));

        camera.position.z = 5;

        const animateConsult = () => {
            requestAnimationFrame(animateConsult);
            sphere.rotation.x += 0.005;
            sphere.rotation.y += 0.005;
            renderer.render(scene, camera);
        };

        // Responsive resize for consulting canvas
        const handleConsultResize = () => {
            const width = consultContainer.clientWidth;
            const height = consultContainer.clientHeight;

            renderer.setSize(width, height);
            camera.aspect = width / height;

            // Adjust scale based on container width
            if (width < 400) {
                sphere.scale.set(0.8, 0.8, 0.8);
            } else {
                sphere.scale.set(1.0, 1.0, 1.0);
            }

            camera.updateProjectionMatrix();
        };

        window.addEventListener('resize', handleConsultResize);
        handleConsultResize(); // Initial call

        animateConsult();
    }
</script>

<!-- GSAP & Form Logic -->
<script>
    // Initialize Brands Carousel
    const brandsSwiper = new Swiper('.brands-carousel', {
        slidesPerView: 2,
        spaceBetween: 30,
        loop: true,
        autoplay: {
            delay: 2500,
            disableOnInteraction: false,
        },
        breakpoints: {
            640: {
                slidesPerView: 3,
            },
            768: {
                slidesPerView: 4,
            },
            1024: {
                slidesPerView: 6,
            },
        },
    });

    // Initialize Lucide icons
    lucide.createIcons();

    // GSAP Scroll Reveal
    gsap.registerPlugin(ScrollTrigger);
    
    document.querySelectorAll('.reveal').forEach((el) => {
        gsap.from(el, {
            scrollTrigger: {
                trigger: el,
                start: "top 85%",
                toggleActions: "play none none none"
            },
            y: 50,
            opacity: 0,
            duration: 1,
            ease: "power3.out"
        });
    });

    // Tilt Cards
    document.querySelectorAll('.tilt-card').forEach(card => {
        card.addEventListener('mousemove', e => {
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            const rotateX = (y - centerY) / 10;
            const rotateY = (centerX - x) / 10;
            
            card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-5px)`;
        });
        
        card.addEventListener('mouseleave', () => {
            card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) translateY(0)`;
        });
    });

    // Form Submission
    const contactForm = document.getElementById('contact-form');
    const formStatus = document.getElementById('form-status');

    if (contactForm && formStatus) {
        contactForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(contactForm);
            const data = Object.fromEntries(formData.entries());
            
            formStatus.classList.remove('hidden', 'bg-red-500/20', 'text-red-400', 'bg-green-500/20', 'text-green-400');
            formStatus.classList.add('block', 'bg-blue-500/20', 'text-blue-400');
            formStatus.textContent = 'Sending message...';

            try {
                const response = await fetch('/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();
                
                formStatus.classList.remove('bg-blue-500/20', 'text-blue-400');
                if (result.success) {
                    formStatus.classList.add('bg-green-500/20', 'text-green-400');
                    formStatus.textContent = result.message;
                    contactForm.reset();
                } else {
                    formStatus.classList.add('bg-red-500/20', 'text-red-400');
                    formStatus.textContent = result.message;
                }
            } catch (error) {
                formStatus.classList.remove('bg-blue-500/20', 'text-blue-400');
                formStatus.classList.add('bg-red-500/20', 'text-red-400');
                formStatus.textContent = 'An error occurred. Please try again later.';
            }
        });
    }

    // Customer Filtering Logic
    const initCustomerFilters = () => {
        const filterButtons = document.querySelectorAll('.customer-filter-btn');
        const customerItems = document.querySelectorAll('.customer-item');

        if (filterButtons.length === 0 || customerItems.length === 0) return;

        filterButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const filter = btn.getAttribute('data-filter');
                
                // Update active button state
                filterButtons.forEach(b => {
                    b.classList.remove('active', 'bg-tech-blue', 'text-white', 'border-tech-blue');
                    b.classList.add('text-white/60', 'bg-white/5', 'border-white/10');
                });
                btn.classList.add('active', 'bg-tech-blue', 'text-white', 'border-tech-blue');
                btn.classList.remove('text-white/60', 'bg-white/5', 'border-white/10');

                // Filter items
                customerItems.forEach(item => {
                    const category = item.getAttribute('data-category');
                    if (filter === 'all' || category === filter) {
                        item.style.display = 'flex';
                        gsap.fromTo(item, { opacity: 0, scale: 0.9 }, { opacity: 1, scale: 1, duration: 0.4, ease: "power2.out" });
                    } else {
                        item.style.display = 'none';
                    }
                });

                // Re-trigger scroll reveal for the grid
                ScrollTrigger.refresh();
            });
        });
    };

    // Initialize on DOM load
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCustomerFilters);
    } else {
        initCustomerFilters();
    }
</script>

