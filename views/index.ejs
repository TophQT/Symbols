        <!-- Brands Section -->
    <section class="py-24 brands-section-bg">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16 space-y-4 reveal">
                <h2 class="text-3xl md:text-4xl font-bold font-grotesk">Brands We Carry</h2>
                <div class="w-20 h-1 bg-tech-blue mx-auto rounded-full"></div>
                <p class="text-white/60 max-w-2xl mx-auto">We partner with industry leaders to provide you with the most reliable and advanced technology solutions.</p>
            </div>

            <!-- Brands Carousel Slider -->
            <div class="swiper brands-carousel reveal">
                <div class="swiper-wrapper items-center">
                    <% if (brandsWeCarry && brandsWeCarry.length > 0) { %>
                        <% brandsWeCarry.forEach((brand) => { %>
                            <div class="swiper-slide flex items-center justify-center px-4">
                                <div class="flex items-center justify-center w-full">
                                    <div class="relative">
                                        <img src="<%= brand.logo %>" alt="<%= brand.name %>" title="<%= brand.name %>" class="max-h-12 md:max-h-16 w-auto object-contain">
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } %>
                </div>
                <!-- Optional Navigation/Pagination (Hidden for cleaner look) -->
                <!-- <div class="swiper-pagination"></div> -->
            </div>

            <% if (!brandsWeCarry || brandsWeCarry.length === 0) { %>
                <!-- Fallback if no brands are uploaded -->
                <div class="text-center py-12 glass-card rounded-2xl border-dashed reveal">
                    <p class="text-white/40">Our partner network is growing. Check back soon!</p>
                </div>
            <% } %>

            <!-- Learn More Button -->
            <div class="text-center mt-12 reveal">
                <a href="/ourbrands" class="inline-flex items-center space-x-2 px-8 py-4 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-lg transition-all duration-300 shadow-lg shadow-tech-blue/20 transform hover:scale-105 hover:-translate-y-1 active:translate-y-0">
                    <span>Learn More</span>
                    <i data-lucide="arrow-right" class="w-5 h-5"></i>
                </a>
            </div>
        </div>
