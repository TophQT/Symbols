                        <!-- Feature Block -->
                        <div class="glass-card p-8 rounded-3xl flex flex-col items-center justify-center text-center space-y-3 group hover:scale-105 transition-transform duration-500 mt-8 bg-tech-blue/5 border-tech-blue/20">
                            <div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center text-white">
                                <i data-lucide="rocket" class="w-7 h-7 animate-pulse"></i>
                            </div>
