                    <!-- Right: Stats & Visual Elements -->
                    <div class="relative z-10 grid grid-cols-2 gap-6">
                        <!-- Stat Card 1 -->
                        <div class="glass-card p-8 rounded-3xl flex flex-col items-center justify-center text-center space-y-3 group hover:scale-105 transition-transform duration-500">
                            <div class="w-14 h-14 bg-tech-blue/10 rounded-2xl flex items-center justify-center text-tech-blue group-hover:bg-tech-blue group-hover:text-white transition-all duration-500">
                                <i data-lucide="users" class="w-7 h-7"></i>
                            </div>
                            <div class="text-3xl font-bold text-white">500+</div>
                            <div class="text-xs font-bold uppercase tracking-widest text-white/40 group-hover:text-tech-blue transition-colors">Enterprise Clients</div>
                        </div>

                        <!-- Stat Card 2 -->
                        <div class="glass-card p-8 rounded-3xl flex flex-col items-center justify-center text-center space-y-3 group hover:scale-105 transition-transform duration-500 mt-8">
                            <div class="w-14 h-14 bg-tech-accent/10 rounded-2xl flex items-center justify-center text-tech-accent group-hover:bg-tech-accent group-hover:text-white transition-all duration-500">
                                <i data-lucide="calendar" class="w-7 h-7"></i>
                            </div>
                            <div class="text-3xl font-bold text-white">30+</div>
                            <div class="text-xs font-bold uppercase tracking-widest text-white/40 group-hover:text-tech-accent transition-colors">Years Experience</div>
                        </div>

                        <!-- Stat Card 3 -->
                        <div class="glass-card p-8 rounded-3xl flex flex-col items-center justify-center text-center space-y-3 group hover:scale-105 transition-transform duration-500">
                            <div class="w-14 h-14 bg-purple-500/10 rounded-2xl flex items-center justify-center text-purple-400 group-hover:bg-purple-500 group-hover:text-white transition-all duration-500">
                                <i data-lucide="brain-circuit" class="w-7 h-7"></i>
                            </div>
                            <div class="text-3xl font-bold text-white">250+</div>
                            <div class="text-xs font-bold uppercase tracking-widest text-white/40 group-hover:text-purple-400 transition-colors">Man-Years Expertise</div>
