                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="relative pl-8 border-l-2 border-purple-500/30 group">
                                <div class="absolute -left-[9px] top-2 w-4 h-4 rounded-full bg-purple-500 border-4 border-tech-dark group-hover:scale-125 transition-transform"></div>
