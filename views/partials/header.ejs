<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Tailwind CSS (via CDN for simplicity, or we can compile it) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Custom Tailwind Configuration -->
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'tech-dark': '#0b0e14',
              'tech-blue': '#3b82f6',
              'tech-accent': '#60a5fa',
              'tech-red': '#ef4444',
            },
            backdropBlur: {
              'xs': '2px',
            },
            animation: {
              'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
              'float': 'float 3s ease-in-out infinite',
            },
            keyframes: {
              float: {
                '0%, 100%': { transform: 'translateY(0)' },
                '50%': { transform: 'translateY(-10px)' },
              }
            }
          }
        }
      }
    </script>
    <!-- GSAP for animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <!-- Three.js -->
    <script async src="https://unpkg.com/es-module-shims@1.8.0/dist/es-module-shims.js"></script>
    <script type="importmap">
      {
        "imports": {
          "three": "https://unpkg.com/three@0.156.1/build/three.module.js",
          "three/addons/": "https://unpkg.com/three@0.156.1/examples/jsm/"
        }
      }
    </script>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap');
      
      :root {
        --tech-bg: #0b0e14;
        --tech-text: #ffffff;
        --tech-glass: rgba(255, 255, 255, 0.03);
        --tech-glass-border: rgba(255, 255, 255, 0.05);
        --tech-card-bg: rgba(255, 255, 255, 0.03);
        --tech-card-border: rgba(255, 255, 255, 0.08);
        --tech-muted: rgba(255, 255, 255, 0.6);
        --tech-subtle: rgba(255, 255, 255, 0.4);
      }

      body.light {
        --tech-bg: #f8fafc;
        --tech-text: #0f172a;
        --tech-glass: rgba(15, 23, 42, 0.03);
        --tech-glass-border: rgba(15, 23, 42, 0.08);
        --tech-card-bg: #ffffff;
        --tech-card-border: rgba(15, 23, 42, 0.1);
        --tech-muted: #334155; /* slate-700 */
        --tech-subtle: #475569; /* slate-600 */
      }

      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--tech-bg);
        color: var(--tech-text);
        overflow-x: hidden;
        transition: background-color 0.5s ease, color 0.5s ease;
      }

      input, textarea, select {
        color: var(--tech-text);
      }

      input::placeholder, textarea::placeholder {
        color: var(--tech-subtle);
      }
      
      .font-grotesk {
        font-family: 'Space Grotesk', sans-serif;
      }

      /* Glassmorphism */
      .glass {
        background: var(--tech-glass);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid var(--tech-glass-border);
        transition: all 0.5s ease;
      }

      .glass-card {
        background: var(--tech-card-bg);
        backdrop-filter: blur(8px);
        border: 1px solid var(--tech-card-border);
        transition: all 0.5s ease, transform 0.3s ease;
      }

      body.light .glass-card {
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
      }

      .glass-card:hover {
        background: var(--tech-glass);
        border-color: rgba(59, 130, 246, 0.3);
        transform: translateY(-5px);
        box-shadow: 0 10px 30px -10px rgba(59, 130, 246, 0.2);
      }

      /* Theme Specific Text & BG Colors */
      .text-white { color: var(--tech-text) !important; transition: color 0.5s ease; }
      .text-white\/80 { color: var(--tech-muted) !important; transition: color 0.5s ease; }
      .text-white\/70 { color: var(--tech-muted) !important; transition: color 0.5s ease; }
      .text-white\/60 { color: var(--tech-subtle) !important; transition: color 0.5s ease; }
      .text-white\/40 { color: var(--tech-subtle) !important; opacity: 0.8; transition: color 0.5s ease; }
      .bg-tech-dark { background-color: var(--tech-bg) !important; transition: background-color 0.5s ease; }
      .bg-white\/5 { background: var(--tech-glass) !important; transition: background-color 0.5s ease; }
      .bg-white\/10 { background: var(--tech-glass-border) !important; transition: background-color 0.5s ease; }
      .border-white\/10 { border-color: var(--tech-glass-border) !important; transition: border-color 0.5s ease; }
      .border-white\/5 { border-color: var(--tech-glass) !important; transition: border-color 0.5s ease; }

      /* Brands Section BG for Light Mode */
      .brands-section-bg {
        background-color: rgba(255, 255, 255, 0.03);
        transition: background-color 0.5s ease;
      }
      body.light .brands-section-bg {
        background-color: #ffffff !important;
      }

      /* Subtle Section BG */
      .section-bg-subtle {
        background-color: rgba(255, 255, 255, 0.02);
        transition: background-color 0.5s ease;
      }
      body.light .section-bg-subtle {
        background-color: #f1f5f9 !important; /* slate-100 */
      }

      /* Animated Underline */
      .nav-link {
        position: relative;
        color: var(--tech-text);
        transition: color 0.5s ease;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: -4px;
        left: 0;
        background-color: #3b82f6;
        transition: width 0.3s ease;
      }
      .nav-link:hover::after {
        width: 100%;
      }

      /* Theme Toggle Styles */
      #theme-toggle-btn, #theme-toggle-btn-mobile {
        /* Base styles for the toggle track */
        background: var(--tech-glass);
        border: 1px solid var(--tech-glass-border);
        transition: all 0.3s ease;
      }
      
      #theme-toggle-btn .bg-white, #theme-toggle-btn-mobile .bg-white {
        /* Styles for the sliding circle */
        background-color: #ffffff; /* Default white for dark mode */
        transition: all 0.3s ease;
      }

      body.light #theme-toggle-btn, body.light #theme-toggle-btn-mobile {
        background: var(--tech-glass);
        border-color: var(--tech-glass-border);
      }

      body.light #theme-toggle-btn .bg-white, body.light #theme-toggle-btn-mobile .bg-white {
        background-color: #f3f4f6; /* Light gray for light mode */
      }
      
      /* Active state (light mode) for the toggle track */
      body.light #theme-toggle-btn, body.light #theme-toggle-btn-mobile {
        background-color: rgba(59, 130, 246, 0.2); /* Tech blue for light mode */
        border-color: rgba(59, 130, 246, 0.3);
      }

      /* Active state (light mode) for the sliding circle */
      body.light #theme-toggle-btn .bg-white, body.light #theme-toggle-btn-mobile .bg-white {
        transform: translateX(28px); /* Move to the right */
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--tech-bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--tech-card-border);
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3b82f6;
      }

      /* Barcode Scanner Laser */
      .laser-line {
        position: absolute;
        width: 100%;
        height: 2px;
        background: rgba(239, 68, 68, 0.8);
        box-shadow: 0 0 15px 2px rgba(239, 68, 68, 0.8);
        animation: scan 3s ease-in-out infinite;
      }

      @keyframes scan {
        0%, 100% { top: 0%; }
        50% { top: 100%; }
      }
    </style>
    <script>
      // Immediate theme check to prevent flash
      (function() {
        const theme = localStorage.getItem('site-theme') || 'dark';
        if (theme === 'light') {
          document.documentElement.classList.add('light');
          document.addEventListener('DOMContentLoaded', () => {
            document.body.classList.add('light');
          });
        }
      })();
    </script>
</head>
<body class="bg-tech-dark text-white">
    <!-- Loading Screen -->
    <div id="loading-screen" class="fixed inset-0 z-[100] flex items-center justify-center bg-tech-dark transition-opacity duration-700">
        <div class="relative">
            <div class="w-16 h-16 border-4 border-tech-blue/20 border-t-tech-blue rounded-full animate-spin"></div>
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-8 h-8 border-4 border-tech-accent/20 border-b-tech-accent rounded-full animate-spin" style="animation-direction: reverse;"></div>
            </div>
        </div>
    </div>

    <!-- Navigation Bar -->
    <header class="fixed top-0 left-0 w-full z-50 transition-all duration-300" id="main-header">
        <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
            <!-- Logo -->
            <a href="/" class="flex items-center group">
                <% if (locals.settings && locals.settings.logo) { %>
                    <img src="<%= settings.logo %>" alt="Logo" class="h-12 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                <% } else if (locals.settings && locals.settings.defaultLogo) { %>
                    <img src="<%= settings.defaultLogo %>" alt="Default Logo" class="h-12 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                <% } else { %>
                    <div class="h-12 w-auto flex items-center justify-center transform group-hover:scale-110 transition-transform duration-300">
                        <i data-lucide="scan-barcode" class="text-tech-blue w-8 h-8"></i>
                    </div>
                <% } %>
            </a>

            <!-- Desktop Menu -->
            <div class="hidden lg:flex items-center space-x-8">
                <a href="/" class="nav-link text-sm font-medium hover:text-blue-600 transition-colors">Home</a>
                <a href="/products" class="nav-link text-sm font-medium hover:text-blue-600 transition-colors">Products</a>
                <a href="/services" class="nav-link text-sm font-medium hover:text-blue-600 transition-colors">Services & Solutions</a>
                <a href="/software-list" class="nav-link text-sm font-medium hover:text-blue-600 transition-colors">Software</a>
                <a href="/updates" class="nav-link text-sm font-medium hover:text-blue-600 transition-colors">Updates</a>
                <a href="/#about-us" class="nav-link text-sm font-medium hover:text-blue-600 transition-colors">About Us</a>
                <div class="flex items-center space-x-4">
                    <!-- Theme Toggle -->
                    <button id="theme-toggle-btn" title="Toggle Light/Dark Mode" class="relative w-14 h-7 rounded-full transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[var(--tech-bg)] focus:ring-tech-blue/50 glass mr-2">
                        <div class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transform transition-transform duration-300 flex items-center justify-center">
                            <i data-lucide="sun" class="w-4 h-4 text-tech-blue light-icon hidden"></i>
                            <i data-lucide="moon" class="w-4 h-4 text-tech-blue dark-icon"></i>
                        </div>
                    </button>
      
                    <a href="/contact" class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-full text-sm font-semibold transition-all shadow-md transform hover:scale-105 active:scale-95">Contact Us</a>
                </div>
            </div>

            <!-- Mobile Menu Toggle -->
            <div class="flex items-center space-x-4 lg:hidden">
                <!-- Mobile Theme Toggle -->
                <button id="theme-toggle-btn-mobile" title="Toggle Light/Dark Mode" class="relative w-14 h-7 rounded-full transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[var(--tech-bg)] focus:ring-tech-blue/50 glass">
                    <div class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transform transition-transform duration-300 flex items-center justify-center">
                        <i data-lucide="moon" class="w-4 h-4 text-tech-blue dark-icon"></i>
                        <i data-lucide="sun" class="w-4 h-4 text-tech-blue light-icon hidden"></i>
                    </div>
                </button>
                <button class="text-white focus:outline-none" id="mobile-menu-btn">
                    <i data-lucide="menu" class="w-7 h-7"></i>
                </button>
            </div>
        </nav>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu" class="fixed inset-0 bg-tech-dark/95 backdrop-blur-xl z-[60] flex flex-col items-center justify-center space-y-8 opacity-0 pointer-events-none transition-all duration-300">
            <button class="absolute top-6 right-6 text-white" id="close-menu-btn">
                <i data-lucide="x" class="w-8 h-8"></i>
            </button>
            <a href="/" class="text-2xl font-bold text-white hover:text-blue-600">Home</a>
            <a href="/products" class="text-2xl font-bold text-white hover:text-blue-600">Products</a>
            <a href="/services" class="text-2xl font-bold text-white hover:text-blue-600">Services & Solutions</a>
            <a href="/software-list" class="text-2xl font-bold text-white hover:text-blue-600">Software</a>
            <a href="/updates" class="text-2xl font-bold text-white hover:text-blue-600">Updates</a>
            <a href="/#about-us" class="text-2xl font-bold text-white hover:text-blue-600">About Us</a>
            <a href="/login" class="text-2xl font-bold text-white hover:text-blue-600">Login</a>
            <a href="/contact" class="px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-full text-lg font-semibold">Contact Us</a>
        </div>
    </header>

    <!-- Theme and Smooth Scroll Script -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Theme Toggle Logic
            const themeBtn = document.getElementById('theme-toggle-btn');
            const themeBtnMobile = document.getElementById('theme-toggle-btn-mobile');
            const body = document.body;
            
            const setupToggle = (btn) => {
                if (!btn) return;
                const darkIcon = btn.querySelector('.dark-icon');
                const lightIcon = btn.querySelector('.light-icon');
                
                btn.addEventListener('click', () => {
                    if (body.classList.contains('light')) {
                        applyDarkTheme();
                    } else {
                        applyLightTheme();
                    }
                });
                
                return { darkIcon, lightIcon };
            };

            const desktopIcons = setupToggle(themeBtn);
            const mobileIcons = setupToggle(themeBtnMobile);

            // Initialize theme from localStorage
            const savedTheme = localStorage.getItem('site-theme') || 'dark';
            if (savedTheme === 'light') {
                applyLightTheme();
            }

            function applyLightTheme() {
                body.classList.add('light');
                document.documentElement.classList.add('light');
                updateIcons(true);
                localStorage.setItem('site-theme', 'light');
                if (window.lucide) lucide.createIcons();
            }

            function applyDarkTheme() {
                body.classList.remove('light');
                document.documentElement.classList.remove('light');
                updateIcons(false);
                localStorage.setItem('site-theme', 'dark');
                if (window.lucide) lucide.createIcons();
            }

            function updateIcons(isLight) {
                [desktopIcons, mobileIcons].forEach(icons => {
                    if (!icons) return;
                    if (isLight) {
                        icons.darkIcon.classList.add('hidden');
                        icons.lightIcon.classList.remove('hidden');
                    } else {
                        icons.darkIcon.classList.remove('hidden');
                        icons.lightIcon.classList.add('hidden');
                    }
                });
            }

            // Smooth scroll for anchor links
            document.querySelectorAll('a[href^="/#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    e.preventDefault();
                    const targetId = this.getAttribute('href').substring(2); // Remove '/#' from href
                    
                    // Check if we're on homepage
                    if (window.location.pathname === '/' || window.location.pathname === '') {
                        // On homepage: scroll to section
                        const targetElement = document.getElementById(targetId);
                        if (targetElement) {
                            targetElement.scrollIntoView({
                                behavior: 'smooth',
                                block: 'start'
                            });
                        }
                    } else {
                        // On other pages: redirect to homepage with hash
                        window.location.href = '/#' + targetId;
                    }
                });
            });
            
            // Handle hash in URL on page load (only for homepage)
            if ((window.location.pathname === '/' || window.location.pathname === '') && window.location.hash) {
                const targetId = window.location.hash.substring(1);
                const targetElement = document.getElementById(targetId);
                if (targetElement) {
                    setTimeout(() => {
                        targetElement.scrollIntoView({
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }, 100);
                }
            }
        });
    </script>
