<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'tech-dark': '#0b0e14',
              'tech-blue': '#3b82f6',
              'tech-accent': '#60a5fa',
              'tech-red': '#ef4444',
            }
          }
        }
      }
    </script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap');
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: #0b0e14;
        color: #ffffff;
        transition: background-color 0.3s ease, color 0.3s ease;
      }
      
      /* Light Mode Styles */
      body.light {
        background-color: #ffffff;
        color: #1f2937;
      }
      
      body.light .glass {
        background: rgba(31, 41, 55, 0.05);
        border: 1px solid rgba(31, 41, 55, 0.1);
      }
      
      body.light .glass-card {
        background: rgba(31, 41, 55, 0.03);
        border: 1px solid rgba(31, 41, 55, 0.08);
      }
      
      body.light .glass-card:hover {
        background: rgba(31, 41, 55, 0.05);
        border-color: rgba(59, 130, 246, 0.2);
      }
      
      body.light .text-white {
        color: #1f2937 !important;
      }
      
      body.light .text-white\/40 {
        color: rgba(31, 41, 55, 0.4) !important;
      }
      
      body.light .text-white\/60 {
        color: rgba(31, 41, 55, 0.6) !important;
      }
      
      body.light .text-white\/80 {
        color: rgba(31, 41, 55, 0.8) !important;
      }
      
      body.light .bg-white\/5 {
        background-color: rgba(31, 41, 55, 0.05) !important;
      }
      
      body.light .bg-white\/10 {
        background-color: rgba(31, 41, 55, 0.1) !important;
      }
      
      body.light .border-white\/5 {
        border-color: rgba(31, 41, 55, 0.05) !important;
      }
      
      body.light .border-white\/10 {
        border-color: rgba(31, 41, 55, 0.1) !important;
      }
      
      body.light .bg-tech-blue\/10 {
        background-color: rgba(59, 130, 246, 0.1) !important;
      }
      
      body.light .bg-tech-blue\/20 {
        background-color: rgba(59, 130, 246, 0.2) !important;
      }
      
      body.light .border-tech-blue\/20 {
        border-color: rgba(59, 130, 246, 0.2) !important;
      }
      
      body.light .border-tech-blue\/30 {
        border-color: rgba(59, 130, 246, 0.3) !important;
      }
      
      body.light #theme-toggle {
        background-color: rgba(31, 41, 55, 0.1);
        border-color: rgba(31, 41, 55, 0.2);
      }
      
      body.light #theme-toggle .bg-white {
        background-color: #f3f4f6;
      }
      
      /* Theme toggle active state */
      #theme-toggle.active {
        background-color: rgba(59, 130, 246, 0.2);
      }
      
      #theme-toggle.active .bg-white {
        transform: translateX(28px);
      }
      
      .font-grotesk {
        font-family: 'Space Grotesk', sans-serif;
      }

      .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .glass-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.3s ease;
      }

      .glass-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(59, 130, 246, 0.3);
        transform: translateY(-5px);
        box-shadow: 0 10px 30px -10px rgba(59, 130, 246, 0.2);
      }
      
      /* Light mode select options */
      body.light select option {
        background-color: #ffffff;
        color: #1f2937;
      }
      
      body.light select option.bg-tech-dark {
        background-color: #ffffff;
      }
    </style>
</head>
<body class="<%= dashboardTheme === 'light' ? 'light' : '' %> bg-tech-dark text-white">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 glass border-r border-white/5 hidden md:flex flex-col fixed h-screen z-40">
            <div class="p-6">
                <a href="/" class="flex items-center group mb-8">
                    <% if (locals.settings && locals.settings.logo) { %>
                        <img src="<%= settings.logo %>" alt="Logo" class="h-10 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                    <% } else if (locals.settings && locals.settings.defaultLogo) { %>
                        <img src="<%= settings.defaultLogo %>" alt="Default Logo" class="h-10 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                    <% } else { %>
                        <div class="h-10 w-auto flex items-center justify-center transform group-hover:scale-110 transition-transform duration-300">
                            <i data-lucide="scan-barcode" class="text-tech-blue w-7 h-7"></i>
                        </div>
                    <% } %>
                </a>
                <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-tech-blue/10 border border-tech-blue/20 text-tech-blue text-[10px] font-bold uppercase tracking-widest mb-4">
                    <span class="w-2 h-2 rounded-full bg-tech-blue"></span>
                    <span>System Online</span>
                </div>
            </div>
            <nav class="flex-grow space-y-1 px-4">
                <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                    <i data-lucide="layout-dashboard" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                    <span class="font-medium">Dashboard</span>
                </a>
                <div class="space-y-1">
                    <a href="/admin/products/brands" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="bookmark" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Brands</span>
                    </a>
                    <a href="/admin/products/categories" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="folder" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Categories</span>
                    </a>
                    <a href="/admin/products" class="flex items-center gap-3 px-4 py-3 bg-tech-blue/10 text-tech-blue border border-tech-blue/20 rounded-xl transition-all">
                        <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                        <span class="font-medium">Products</span>
                    </a>
                    <a href="/admin/brandswecarry" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="image" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Brands We Carry</span>
                    </a>                    <a href="/admin/software" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="package" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Software</span>
                    </a>

                </div>
                <a href="/admin/settings" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                    <i data-lucide="settings" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                    <span class="font-medium">Settings</span>
                </a>
            </nav>
            <div class="p-4 mt-auto">
                <a href="/admin/logout" class="flex items-center gap-3 px-4 py-3 text-tech-red hover:bg-tech-red/10 rounded-xl transition-all group">
                    <i data-lucide="log-out" class="w-5 h-5"></i>
                    <span class="font-medium">Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-grow md:ml-64 p-6 lg:p-10">
            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
                <div class="space-y-1">
                    <h1 class="text-3xl font-bold font-grotesk text-white">Product Management</h1>
                    <p class="text-white/40 text-sm">Create and manage your system products.</p>
                </div>
                <div class="flex items-center gap-3">
                    <!-- Theme Toggle - Changed from server-side link to client-side button -->
                    <button id="theme-toggle" class="relative w-14 h-7 bg-white/10 border border-white/20 rounded-full transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-tech-blue/50">
                        <div class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transform transition-transform duration-300 flex items-center justify-center">
                            <i data-lucide="sun" class="w-3 h-3 text-tech-blue"></i>
                            <i data-lucide="moon" class="w-3 h-3 text-tech-blue hidden"></i>
                        </div>
                    </button>
                    <div class="flex items-center gap-3 bg-white/5 border border-white/10 p-2 rounded-2xl pr-6">
                        <div class="w-12 h-12 rounded-xl bg-tech-blue/20 flex items-center justify-center text-tech-blue font-bold border border-tech-blue/30 shadow-lg shadow-tech-blue/10">
                            A
                        </div>
                        <div>
                            <p class="text-sm font-bold text-white leading-none">Admin User</p>
                            <p class="text-[10px] text-white/40 uppercase tracking-widest mt-1">Super Admin</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Success/Error Messages -->
            <% if (success) { %>
                <div class="mb-6 p-4 bg-green-500/10 border border-green-500/30 rounded-xl flex items-center gap-3">
                    <i data-lucide="check-circle" class="w-5 h-5 text-green-500"></i>
                    <span class="text-green-500 font-medium"><%= success %></span>
                </div>
            <% } %>

            <% if (error) { %>
                <div class="mb-6 p-4 bg-tech-red/10 border border-tech-red/30 rounded-xl flex items-center gap-3">
                    <i data-lucide="alert-circle" class="w-5 h-5 text-tech-red"></i>
                    <span class="text-tech-red font-medium"><%= error %></span>
                </div>
            <% } %>

            <!-- Product Creation Form Card -->
            <div class="glass-card rounded-3xl p-8 border border-white/5 shadow-soft">
                <form action="/admin/products" method="POST" enctype="multipart/form-data" class="space-y-8">
                    <div class="flex items-center justify-between mb-2">
                        <div>
                            <h2 class="text-xl font-bold font-grotesk text-white">Create New Product</h2>
                            <p class="text-white/40 text-sm">Add a new product to your catalog with image and details.</p>
                        </div>
                        <div class="flex items-center space-x-2 px-3 py-1.5 rounded-full bg-tech-blue/10 border border-tech-blue/20">
                            <i data-lucide="plus-circle" class="w-4 h-4 text-tech-blue"></i>
                            <span class="text-tech-blue text-xs font-medium">New Entry</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <!-- Left Side: Basic Info -->
                        <div class="space-y-6">
                            <div>
                                <label for="name" class="block text-sm font-medium text-white/60 mb-2">Product Name</label>
                                <input type="text" name="name" id="name" required placeholder="Enter product name" 
                                    class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                            </div>

                            <div>
                                <label for="brand" class="block text-sm font-medium text-white/60 mb-2">Select Brand</label>
                                <select name="brand" id="brand" required
                                    class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all appearance-none">
                                    <option value="" disabled selected>-- Choose Brand --</option>
                                    <% brands.forEach(brand => { %>
                                        <option value="<%= brand._id %>" class="bg-tech-dark"><%= brand.name %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div>
                                <label for="category" class="block text-sm font-medium text-white/60 mb-2">Select Category</label>
                                <select name="category" id="category" required
                                    class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all appearance-none">
                                    <option value="" disabled selected>-- Choose Category --</option>
                                    <% categories.forEach(category => { %>
                                        <option value="<%= category._id %>" class="bg-tech-dark"><%= category.name %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <!-- Right Side: Image Upload -->
                        <div class="space-y-6">
                            <div>
                                <label class="block text-sm font-medium text-white/60 mb-2">Product Image</label>
                                <div class="relative group h-full min-h-[200px]">
                                    <input type="file" name="image" id="image-upload" accept="image/*" required class="hidden">
                                    <label for="image-upload" class="cursor-pointer block h-full min-h-[200px] border-2 border-dashed border-white/10 rounded-2xl hover:border-tech-blue/50 transition-all group overflow-hidden bg-white/2">
                                        <div id="image-preview-container" class="flex flex-col items-center justify-center h-full p-6 text-center">
                                            <i data-lucide="upload-cloud" class="w-12 h-12 text-white/20 group-hover:text-tech-blue transition-colors mb-4"></i>
                                            <p class="text-white/40 group-hover:text-white transition-colors font-medium">Click to upload product image</p>
                                            <p class="text-[10px] text-white/20 mt-2 uppercase tracking-widest">Supports JPG, PNG, WebP (Max 5MB)</p>
                                        </div>
                                        <img id="image-preview" src="#" alt="Preview" class="hidden w-full h-full object-contain p-4">
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex justify-end pt-4">
                        <button type="submit" class="px-8 py-3 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-xl transition-all shadow-lg shadow-tech-blue/20 transform hover:-translate-y-1 active:translate-y-0 flex items-center gap-2">
                            <i data-lucide="save" class="w-5 h-5"></i>
                            Save Product
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>

    <script>
        // Initialize Lucide icons
        lucide.createIcons();

        // Sync session theme with localStorage for compatibility with the rest of the dashboard
        const currentTheme = '<%= dashboardTheme %>';
        localStorage.setItem('dashboard-theme', currentTheme);

        // Theme Toggle Functionality
        const themeToggle = document.getElementById('theme-toggle');
        const body = document.body;
        
        // Check for saved theme preference or default to dark mode
        const savedTheme = localStorage.getItem('dashboard-theme') || '<%= dashboardTheme %>' || 'dark';
        body.classList.toggle('light', savedTheme === 'light');
        themeToggle.classList.toggle('active', savedTheme === 'light');
        
        // Update icon visibility based on theme
        const updateIcons = () => {
            const sunIcon = document.querySelector('#theme-toggle [data-lucide="sun"]');
            const moonIcon = document.querySelector('#theme-toggle [data-lucide="moon"]');
            if (sunIcon && moonIcon) {
                if (body.classList.contains('light')) {
                    sunIcon.classList.remove('hidden');
                    moonIcon.classList.add('hidden');
                } else {
                    sunIcon.classList.add('hidden');
                    moonIcon.classList.remove('hidden');
                }
            }
        };
        
        // Initial icon update
        updateIcons();
        
        // Theme toggle event listener
        themeToggle.addEventListener('click', () => {
            const isLight = body.classList.toggle('light');
            themeToggle.classList.toggle('active', isLight);
            
            // Save theme preference
            localStorage.setItem('dashboard-theme', isLight ? 'light' : 'dark');
            
            // Update icons
            updateIcons();
            
            // Re-initialize Lucide icons for theme change
            setTimeout(() => {
                lucide.createIcons();
            }, 100);
        });

        // Dynamic category filtering
        const brandSelect = document.getElementById('brand');
        const categorySelect = document.getElementById('category');

        brandSelect.addEventListener('change', async function() {
            const brandId = this.value;
            if (!brandId) {
                categorySelect.disabled = true;
                categorySelect.innerHTML = '<option value="" disabled selected>-- Select a Brand First --</option>';
                return;
            }

            // Enable and show loading
            categorySelect.disabled = false;
            categorySelect.innerHTML = '<option value="" disabled selected>Loading categories...</option>';

            try {
                const response = await fetch(`/admin/api/categories/${brandId}`);
                const categories = await response.json();

                // Clear and populate category dropdown
                categorySelect.innerHTML = '<option value="" disabled selected>-- Choose Category --</option>';
                
                if (categories.length > 0) {
                    categories.forEach(category => {
                        const option = document.createElement('option');
                        option.value = category._id;
                        option.textContent = category.name;
                        option.className = 'bg-tech-dark';
                        categorySelect.appendChild(option);
                    });
                } else {
                    categorySelect.innerHTML = '<option value="" disabled selected>No categories for this brand</option>';
                }
            } catch (error) {
                console.error('Error fetching categories:', error);
                categorySelect.innerHTML = '<option value="" disabled selected>Error loading categories</option>';
            }
        });

        // Image preview logic
        const imageUpload = document.getElementById('image-upload');
        const imagePreview = document.getElementById('image-preview');
        const previewContainer = document.getElementById('image-preview-container');

        imageUpload.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;
                    imagePreview.classList.remove('hidden');
                    previewContainer.classList.add('hidden');
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
</body>
</html>