<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'tech-dark': '#0b0e14',
              'tech-blue': '#3b82f6',
              'tech-accent': '#60a5fa',
              'tech-red': '#ef4444',
            }
          }
        }
      }
    </script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap');
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: #0b0e14;
        color: #ffffff;
      }
      
      .font-grotesk {
        font-family: 'Space Grotesk', sans-serif;
      }

      .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .glass-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.3s ease;
      }

      .glass-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(59, 130, 246, 0.3);
        transform: translateY(-5px);
        box-shadow: 0 10px 30px -10px rgba(59, 130, 246, 0.2);
      }
    </style>
</head>
<body class="bg-tech-dark text-white">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 glass border-r border-white/5 hidden md:flex flex-col fixed h-screen z-40">
            <div class="p-6">
                <a href="/" class="flex items-center group mb-8">
                    <% if (locals.settings && locals.settings.logo) { %>
                        <img src="<%= settings.logo %>" alt="Logo" class="h-10 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                    <% } else if (locals.settings && locals.settings.defaultLogo) { %>
                        <img src="<%= settings.defaultLogo %>" alt="Default Logo" class="h-10 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                    <% } else { %>
                        <div class="h-10 w-auto flex items-center justify-center transform group-hover:scale-110 transition-transform duration-300">
                            <i data-lucide="scan-barcode" class="text-tech-blue w-7 h-7"></i>
                        </div>
                    <% } %>
                </a>
                <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-tech-blue/10 border border-tech-blue/20 text-tech-blue text-[10px] font-bold uppercase tracking-widest mb-4">
                    <span class="w-2 h-2 rounded-full bg-tech-blue"></span>
                    <span>System Online</span>
                </div>
            </div>
            <nav class="flex-grow space-y-1 px-4">
                <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-3 bg-tech-blue/10 text-tech-blue border border-tech-blue/20 rounded-xl transition-all">
                    <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
                    <span class="font-medium">Dashboard</span>
                </a>
                <a href="#" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                    <i data-lucide="users" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                    <span class="font-medium">User Management</span>
                </a>
                <a href="/admin/settings" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                    <i data-lucide="settings" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                    <span class="font-medium">Settings</span>
                </a>
            </nav>
            <div class="p-4 mt-auto">
                <a href="/admin/logout" class="flex items-center gap-3 px-4 py-3 text-tech-red hover:bg-tech-red/10 rounded-xl transition-all group">
                    <i data-lucide="log-out" class="w-5 h-5"></i>
                    <span class="font-medium">Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-grow md:ml-64 p-6 lg:p-10">
            <!-- Dashboard Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
                <div class="space-y-1">
                    <h1 class="text-3xl font-bold font-grotesk text-white">Dashboard Overview</h1>
                    <p class="text-white/40 text-sm">Welcome back, Admin. Here's what's happening today.</p>
                </div>
                <div class="flex items-center gap-3 bg-white/5 border border-white/10 p-2 rounded-2xl pr-6">
                    <div class="w-12 h-12 rounded-xl bg-tech-blue/20 flex items-center justify-center text-tech-blue font-bold border border-tech-blue/30 shadow-lg shadow-tech-blue/10">
                        A
                    </div>
                    <div>
                        <p class="text-sm font-bold text-white leading-none">Admin User</p>
                        <p class="text-[10px] text-white/40 uppercase tracking-widest mt-1">Super Admin</p>
                    </div>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
                <!-- Stat Card 1 -->
                <div class="glass-card p-6 rounded-2xl border border-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center text-tech-blue">
                            <i data-lucide="eye" class="w-6 h-6"></i>
                        </div>
                        <span class="text-green-500 text-xs font-bold bg-green-500/10 px-2 py-1 rounded-lg">+12.5%</span>
                    </div>
                    <h3 class="text-white/40 text-xs font-bold uppercase tracking-widest">Total Visitors</h3>
                    <p class="text-2xl font-bold text-white mt-1">24,512</p>
                </div>

                <!-- Stat Card 2 -->
                <div class="glass-card p-6 rounded-2xl border border-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-tech-accent/10 rounded-xl flex items-center justify-center text-tech-accent">
                            <i data-lucide="shopping-cart" class="w-6 h-6"></i>
                        </div>
                        <span class="text-green-500 text-xs font-bold bg-green-500/10 px-2 py-1 rounded-lg">+8.2%</span>
                    </div>
                    <h3 class="text-white/40 text-xs font-bold uppercase tracking-widest">New Orders</h3>
                    <p class="text-2xl font-bold text-white mt-1">1,205</p>
                </div>

                <!-- Stat Card 3 -->
                <div class="glass-card p-6 rounded-2xl border border-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center text-purple-500">
                            <i data-lucide="dollar-sign" class="w-6 h-6"></i>
                        </div>
                        <span class="text-tech-red text-xs font-bold bg-tech-red/10 px-2 py-1 rounded-lg">-3.1%</span>
                    </div>
                    <h3 class="text-white/40 text-xs font-bold uppercase tracking-widest">Total Revenue</h3>
                    <p class="text-2xl font-bold text-white mt-1">$45,210</p>
                </div>

                <!-- Stat Card 4 -->
                <div class="glass-card p-6 rounded-2xl border border-white/5">
                    <div class="flex items-center justify-between mb-4">
                        <div class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center text-orange-500">
                            <i data-lucide="activity" class="w-6 h-6"></i>
                        </div>
                        <span class="text-green-500 text-xs font-bold bg-green-500/10 px-2 py-1 rounded-lg">+5.4%</span>
                    </div>
                    <h3 class="text-white/40 text-xs font-bold uppercase tracking-widest">Active Users</h3>
                    <p class="text-2xl font-bold text-white mt-1">3,842</p>
                </div>
            </div>

            <!-- Content Sections -->
            <div class="grid lg:grid-cols-3 gap-8 mb-10">
                <!-- Recent Activity -->
                <div class="lg:col-span-2 glass-card rounded-3xl p-8 border border-white/5">
                    <div class="flex items-center justify-between mb-8">
                        <h2 class="text-xl font-bold font-grotesk text-white">System Performance</h2>
                    </div>
                    <div class="space-y-8">
                        <div class="relative h-64 bg-white/5 rounded-2xl flex items-center justify-center border border-white/5 overflow-hidden">
                             <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(#3b82f6 1px, transparent 1px); background-size: 20px 20px;"></div>
                             <div class="relative flex flex-col items-center text-center p-6">
                                <i data-lucide="bar-chart" class="w-12 h-12 text-tech-blue/40 mb-4"></i>
                                <p class="text-white/40 text-sm max-w-xs">Performance visualization module would be integrated here.</p>
                             </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="glass-card rounded-3xl p-8 border border-white/5">
                    <h2 class="text-xl font-bold font-grotesk text-white mb-8">Quick Actions</h2>
                    <div class="grid grid-cols-1 gap-4">
                        <button class="flex items-center justify-between p-4 bg-white/5 hover:bg-tech-blue/10 border border-white/10 hover:border-tech-blue/30 rounded-2xl transition-all group">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-tech-blue/20 rounded-xl flex items-center justify-center text-tech-blue group-hover:scale-110 transition-transform">
                                    <i data-lucide="plus" class="w-5 h-5"></i>
                                </div>
                                <span class="font-medium text-white/80 group-hover:text-white">Add New Item</span>
                            </div>
                            <i data-lucide="chevron-right" class="w-4 h-4 text-white/20 group-hover:text-tech-blue"></i>
                        </button>
                        <button class="flex items-center justify-between p-4 bg-white/5 hover:bg-tech-blue/10 border border-white/10 hover:border-tech-blue/30 rounded-2xl transition-all group">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-tech-accent/20 rounded-xl flex items-center justify-center text-tech-accent group-hover:scale-110 transition-transform">
                                    <i data-lucide="user-plus" class="w-5 h-5"></i>
                                </div>
                                <span class="font-medium text-white/80 group-hover:text-white">Invite User</span>
                            </div>
                            <i data-lucide="chevron-right" class="w-4 h-4 text-white/20 group-hover:text-tech-blue"></i>
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
