<%- include('partials/header') %>

<style>
    /* Light mode improvements for form inputs */
    body.light input[type="text"],
    body.light input[type="email"],
    body.light input[type="tel"],
    body.light select,
    body.light textarea {
        color: #1f2937 !important;
        background-color: rgba(249, 250, 251, 0.95) !important;
        border-color: rgba(156, 163, 175, 0.3) !important;
    }
    
    body.light input::placeholder,
    body.light textarea::placeholder {
        color: #9ca3af !important;
    }
    
    body.light select option {
        background-color: #ffffff !important;
        color: #1f2937 !important;
    }
    
    body.light input:focus,
    body.light select:focus,
    body.light textarea:focus {
        border-color: rgba(59, 130, 246, 0.5) !important;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1) !important;
    }
</style>

<main class="pt-32 pb-24">
    <div class="container mx-auto px-6">
        <!-- Page Title / Intro -->
        <div class="text-center mb-20 space-y-4 reveal">
            <h1 class="text-5xl md:text-7xl font-bold font-grotesk leading-tight">Services & Solutions</h1>
            <p class="text-white/60 max-w-2xl mx-auto text-lg">Expertise that drives digital transformation across industries.</p>
            <div class="w-24 h-1 bg-tech-blue mx-auto rounded-full mt-8 opacity-50"></div>
        </div>

        <!-- Services Section -->
        <section class="mb-32">
            <div class="flex items-center space-x-4 mb-12 reveal">
                <h2 class="text-3xl md:text-4xl font-bold font-grotesk">Our Services</h2>
                <div class="h-px flex-grow bg-white/10"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Service Card 1: Consulting and System Integration -->
                <div class="glass-card group p-8 rounded-3xl reveal hover:shadow-2xl hover:shadow-tech-blue/10 transition-all duration-500 border border-white/5 hover:border-tech-blue/30 relative overflow-hidden" style="transition-delay: 100ms">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-tech-blue/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-tech-blue/10 transition-colors"></div>
                    <div class="w-16 h-16 bg-tech-blue/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
                        <i data-lucide="users" class="text-tech-blue w-8 h-8"></i>
                    </div>
                    <h3 class="text-2xl font-bold font-grotesk mb-4">Consulting and System Integration</h3>
                    <p class="text-white/60 leading-relaxed">Expert guidance to bridge the gap between complex hardware and your existing enterprise software for seamless operations.</p>
                </div>

                <!-- Service Card 2: Project Management -->
                <div class="glass-card group p-8 rounded-3xl reveal hover:shadow-2xl hover:shadow-tech-accent/10 transition-all duration-500 border border-white/5 hover:border-tech-accent/30 relative overflow-hidden" style="transition-delay: 200ms">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-tech-accent/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-tech-accent/10 transition-colors"></div>
                    <div class="w-16 h-16 bg-tech-accent/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
                        <i data-lucide="clipboard-list" class="text-tech-accent w-8 h-8"></i>
                    </div>
                    <h3 class="text-2xl font-bold font-grotesk mb-4">Project Management</h3>
                    <p class="text-white/60 leading-relaxed">End-to-end management of technology deployments, ensuring projects are delivered on time, within scope, and on budget.</p>
                </div>

                <!-- Service Card 3: Event Data-Process Service -->
                <div class="glass-card group p-8 rounded-3xl reveal hover:shadow-2xl hover:shadow-purple-500/10 transition-all duration-500 border border-white/5 hover:border-purple-500/30 relative overflow-hidden" style="transition-delay: 300ms">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-purple-500/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-purple-500/10 transition-colors"></div>
                    <div class="w-16 h-16 bg-purple-500/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
                        <i data-lucide="database" class="text-purple-400 w-8 h-8"></i>
                    </div>
                    <h3 class="text-2xl font-bold font-grotesk mb-4">Event Data-Process Service</h3>
                    <p class="text-white/60 leading-relaxed">Real-time data capture and processing services for large-scale events, ensuring accuracy and immediate insights.</p>
                </div>

                <!-- Service Card 4: Software Development and Programming -->
                <div class="glass-card group p-8 rounded-3xl reveal hover:shadow-2xl hover:shadow-tech-blue/10 transition-all duration-500 border border-white/5 hover:border-tech-blue/30 relative overflow-hidden" style="transition-delay: 400ms">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-tech-blue/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-tech-blue/10 transition-colors"></div>
                    <div class="w-16 h-16 bg-tech-blue/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
                        <i data-lucide="code-2" class="text-tech-blue w-8 h-8"></i>
                    </div>
                    <h3 class="text-2xl font-bold font-grotesk mb-4">Software Development and Programming</h3>
                    <p class="text-white/60 leading-relaxed">Custom software solutions tailored to your unique business logic, from mobile applications to backend systems.</p>
                </div>

                <!-- Service Card 5: Maintenance Contracts and Service Calls -->
                <div class="glass-card group p-8 rounded-3xl reveal hover:shadow-2xl hover:shadow-tech-accent/10 transition-all duration-500 border border-white/5 hover:border-tech-accent/30 relative overflow-hidden" style="transition-delay: 500ms">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-tech-accent/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-tech-accent/10 transition-colors"></div>
                    <div class="w-16 h-16 bg-tech-accent/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
                        <i data-lucide="wrench" class="text-tech-accent w-8 h-8"></i>
                    </div>
                    <h3 class="text-2xl font-bold font-grotesk mb-4">Maintenance Contracts and Service Calls</h3>
                    <p class="text-white/60 leading-relaxed">Comprehensive support and maintenance to ensure your critical systems remain operational with minimal downtime.</p>
                </div>

                <!-- Service Card 6: Printing and Verification Service -->
                <div class="glass-card group p-8 rounded-3xl reveal hover:shadow-2xl hover:shadow-purple-500/10 transition-all duration-500 border border-white/5 hover:border-purple-500/30 relative overflow-hidden" style="transition-delay: 600ms">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-purple-500/5 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-purple-500/10 transition-colors"></div>
                    <div class="w-16 h-16 bg-purple-500/10 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500">
                        <i data-lucide="printer" class="text-purple-400 w-8 h-8"></i>
                    </div>
                    <h3 class="text-2xl font-bold font-grotesk mb-4">Printing and Verification Service</h3>
                    <p class="text-white/60 leading-relaxed">High-quality industrial printing and barcode verification services to ensure 100% scannability across your supply chain.</p>
                </div>
            </div>
        </section>

        <!-- Solutions Section -->
        <section class="mb-12">
            <div class="flex items-center space-x-4 mb-12 reveal">
                <h2 class="text-3xl md:text-4xl font-bold font-grotesk">Industry Solutions</h2>
                <div class="h-px flex-grow bg-white/10"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <!-- Solution Card 1: Enterprise -->
                <div class="glass-card group p-6 rounded-[2rem] reveal hover:bg-white/5 transition-all duration-300 border border-white/5 hover:border-tech-blue/20" style="transition-delay: 100ms">
                    <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-6 transition-transform">
                        <i data-lucide="building-2" class="text-tech-blue w-6 h-6"></i>
                    </div>
                    <h4 class="text-xl font-bold font-grotesk mb-2">Enterprise</h4>
                    <p class="text-white/60 text-sm leading-relaxed">Scalable technology architectures designed to unify complex corporate operations and data management.</p>
                </div>

                <!-- Solution Card 2: Government -->
                <div class="glass-card group p-6 rounded-[2rem] reveal hover:bg-white/5 transition-all duration-300 border border-white/5 hover:border-tech-blue/20" style="transition-delay: 200ms">
                    <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-6 transition-transform">
                        <i data-lucide="landmark" class="text-tech-blue w-6 h-6"></i>
                    </div>
                    <h4 class="text-xl font-bold font-grotesk mb-2">Government</h4>
                    <p class="text-white/60 text-sm leading-relaxed">Secure and reliable data processing solutions meeting the stringent requirements of public sector agencies.</p>
                </div>

                <!-- Solution Card 3: Retail -->
                <div class="glass-card group p-6 rounded-[2rem] reveal hover:bg-white/5 transition-all duration-300 border border-white/5 hover:border-tech-blue/20" style="transition-delay: 300ms">
                    <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-6 transition-transform">
                        <i data-lucide="shopping-cart" class="text-tech-blue w-6 h-6"></i>
                    </div>
                    <h4 class="text-xl font-bold font-grotesk mb-2">Retail</h4>
                    <p class="text-white/60 text-sm leading-relaxed">Smart inventory and point-of-sale integrations that enhance customer experience and operational efficiency.</p>
                </div>

                <!-- Solution Card 4: Wholesale Distribution -->
                <div class="glass-card group p-6 rounded-[2rem] reveal hover:bg-white/5 transition-all duration-300 border border-white/5 hover:border-tech-blue/20" style="transition-delay: 400ms">
                    <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-6 transition-transform">
                        <i data-lucide="boxes" class="text-tech-blue w-6 h-6"></i>
                    </div>
                    <h4 class="text-xl font-bold font-grotesk mb-2">Wholesale Distribution</h4>
                    <p class="text-white/60 text-sm leading-relaxed">Advanced tracking and logistics systems to optimize high-volume movement and warehouse management.</p>
                </div>

                <!-- Solution Card 5: Transportation -->
                <div class="glass-card group p-6 rounded-[2rem] reveal hover:bg-white/5 transition-all duration-300 border border-white/5 hover:border-tech-blue/20" style="transition-delay: 500ms">
                    <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-6 transition-transform">
                        <i data-lucide="truck" class="text-tech-blue w-6 h-6"></i>
                    </div>
                    <h4 class="text-xl font-bold font-grotesk mb-2">Transportation</h4>
                    <p class="text-white/60 text-sm leading-relaxed">Real-time fleet tracking and logistics data solutions for efficient transit and delivery networks.</p>
                </div>

                <!-- Solution Card 6: Manufacturing and Production -->
                <div class="glass-card group p-6 rounded-[2rem] reveal hover:bg-white/5 transition-all duration-300 border border-white/5 hover:border-tech-blue/20" style="transition-delay: 600ms">
                    <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-6 transition-transform">
                        <i data-lucide="factory" class="text-tech-blue w-6 h-6"></i>
                    </div>
                    <h4 class="text-xl font-bold font-grotesk mb-2">Manufacturing and Production</h4>
                    <p class="text-white/60 text-sm leading-relaxed">Automation and quality control systems that streamline production lines and monitor asset performance.</p>
                </div>

                <!-- Solution Card 7: Healthcare -->
                <div class="glass-card group p-6 rounded-[2rem] reveal hover:bg-white/5 transition-all duration-300 border border-white/5 hover:border-tech-blue/20" style="transition-delay: 700ms">
                    <div class="w-12 h-12 bg-tech-blue/10 rounded-xl flex items-center justify-center mb-4 group-hover:rotate-6 transition-transform">
                        <i data-lucide="heart-pulse" class="text-tech-blue w-6 h-6"></i>
                    </div>
                    <h4 class="text-xl font-bold font-grotesk mb-2">Healthcare</h4>
                    <p class="text-white/60 text-sm leading-relaxed">Precision tracking for medical assets and patient data systems focused on accuracy and security.</p>
                </div>
            </div>
        </section>

        <!-- Inquiry Forms Section -->
        <section class="mb-32 reveal">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold font-grotesk mb-4">Get In Touch</h2>
                <p class="text-white/60 max-w-2xl mx-auto text-lg">Have questions about our services or industry solutions? We're here to help.</p>
                <div class="w-24 h-1 bg-tech-blue mx-auto rounded-full mt-8 opacity-50"></div>
            </div>

            <div class="max-w-4xl mx-auto">
                <!-- Toggle Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
                    <button 
                        id="services-inquiry-btn" 
                        onclick="showServicesForm()" 
                        class="px-8 py-4 bg-tech-blue text-white rounded-lg font-semibold transition-all duration-300 hover:bg-tech-blue/80 transform hover:scale-105 shadow-lg shadow-tech-blue/20">
                        Our Services Inquiry
                    </button>
                    <button 
                        id="industry-inquiry-btn" 
                        onclick="showIndustryForm()" 
                        class="px-8 py-4 bg-white/10 text-white rounded-lg font-semibold transition-all duration-300 hover:bg-white/20 transform hover:scale-105 border border-white/20">
                        Industry Solutions Inquiry
                    </button>
                </div>

                <!-- Forms Container -->
                <div class="glass-card rounded-2xl shadow-xl p-8 border border-white/5">
                    <!-- Success/Error Messages -->
                    <% if (typeof success !== 'undefined' && success) { %>
                        <div class="mb-6 p-4 bg-green-500/20 border border-green-500/30 rounded-lg text-green-100 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <i data-lucide="check-circle" class="w-5 h-5"></i>
                                <span><%= success %></span>
                            </div>
                        </div>
                    <% } %>
                    
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="mb-6 p-4 bg-red-500/20 border border-red-500/30 rounded-lg text-red-100 text-center">
                            <div class="flex items-center justify-center gap-2">
                                <i data-lucide="alert-circle" class="w-5 h-5"></i>
                                <span><%= error %></span>
                            </div>
                        </div>
                    <% } %>
                    
                    <!-- Form 1: Our Services Inquiry -->
                    <div id="services-inquiry-form" class="space-y-6">
                        <div class="text-center mb-8">
                            <h3 class="text-2xl font-bold font-grotesk text-white mb-2">Our Services Inquiry</h3>
                            <p class="text-white/60">Tell us about the service you're interested in</p>
                        </div>

                        <form action="/inquiry/services" method="POST" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label for="services-fullname" class="block text-sm font-medium text-white/60 mb-2">Full Name</label>
                                    <input 
                                        type="text" 
                                        id="services-fullname" 
                                        name="fullname" 
                                        required
                                        value="<%= typeof formData !== 'undefined' && formData.fullname ? formData.fullname : '' %>"
                                        placeholder="Enter your full name"
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                </div>
                                <div>
                                    <label for="services-email" class="block text-sm font-medium text-white/60 mb-2">Email Address</label>
                                    <input 
                                        type="email" 
                                        id="services-email" 
                                        name="email" 
                                        required
                                        value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
                                        placeholder="your.email@example.com"
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label for="services-phone" class="block text-sm font-medium text-white/60 mb-2">Contact Number</label>
                                    <input 
                                        type="tel" 
                                        id="services-phone" 
                                        name="phone" 
                                        required
                                        value="<%= typeof formData !== 'undefined' && formData.phone ? formData.phone : '' %>"
                                        placeholder="+1 (555) 123-4567"
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                </div>
                                <div>
                                    <label for="services-service" class="block text-sm font-medium text-white/60 mb-2">What Service are you Interested in?</label>
                                    <select 
                                        id="services-service" 
                                        name="service" 
                                        required
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                        <option value="">Select a service</option>
                                        <option value="consulting" <%= typeof formData !== 'undefined' && formData.service === 'consulting' ? 'selected' : '' %>>Consulting and System Integration</option>
                                        <option value="project-management" <%= typeof formData !== 'undefined' && formData.service === 'project-management' ? 'selected' : '' %>>Project Management</option>
                                        <option value="event-data" <%= typeof formData !== 'undefined' && formData.service === 'event-data' ? 'selected' : '' %>>Event Data-Process Service</option>
                                        <option value="software-development" <%= typeof formData !== 'undefined' && formData.service === 'software-development' ? 'selected' : '' %>>Software Development and Programming</option>
                                        <option value="maintenance" <%= typeof formData !== 'undefined' && formData.service === 'maintenance' ? 'selected' : '' %>>Maintenance Contracts and Service Calls</option>
                                        <option value="printing" <%= typeof formData !== 'undefined' && formData.service === 'printing' ? 'selected' : '' %>>Printing and Verification Service</option>
                                        <option value="others" <%= typeof formData !== 'undefined' && formData.service === 'others' ? 'selected' : '' %>>Others</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <label for="services-inquiry" class="block text-sm font-medium text-white/60 mb-2">Inquiry</label>
                                <textarea 
                                    id="services-inquiry" 
                                    name="inquiry" 
                                    rows="4" 
                                    required
                                    placeholder="Please describe your inquiry in detail..."
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:border-tech-blue transition-colors"><%= typeof formData !== 'undefined' && formData.inquiry ? formData.inquiry : '' %></textarea>
                            </div>

                            <div class="flex justify-center pt-4">
                                <button 
                                    type="submit" 
                                    class="px-8 py-3 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-lg transition-all duration-300 shadow-lg shadow-tech-blue/20 transform hover:scale-105 hover:-translate-y-1 active:translate-y-0 flex items-center gap-2">
                                    <i data-lucide="send" class="w-5 h-5"></i>
                                    Submit Inquiry
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Form 2: Industry Solutions Inquiry -->
                    <div id="industry-inquiry-form" class="space-y-6 hidden">
                        <div class="text-center mb-8">
                            <h3 class="text-2xl font-bold font-grotesk text-white mb-2">Industry Solutions Inquiry</h3>
                            <p class="text-white/60">Let us know about your industry-specific needs</p>
                        </div>

                        <form action="/inquiry/industry" method="POST" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label for="industry-fullname" class="block text-sm font-medium text-white/60 mb-2">Full Name</label>
                                    <input 
                                        type="text" 
                                        id="industry-fullname" 
                                        name="fullname" 
                                        required
                                        value="<%= typeof formData !== 'undefined' && formData.fullname ? formData.fullname : '' %>"
                                        placeholder="Enter your full name"
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                </div>
                                <div>
                                    <label for="industry-email" class="block text-sm font-medium text-white/60 mb-2">Email Address</label>
                                    <input 
                                        type="email" 
                                        id="industry-email" 
                                        name="email" 
                                        required
                                        value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
                                        placeholder="your.email@example.com"
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label for="industry-phone" class="block text-sm font-medium text-white/60 mb-2">Contact Number</label>
                                    <input 
                                        type="tel" 
                                        id="industry-phone" 
                                        name="phone" 
                                        required
                                        value="<%= typeof formData !== 'undefined' && formData.phone ? formData.phone : '' %>"
                                        placeholder="+1 (555) 123-4567"
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                </div>
                                <div>
                                    <label for="industry-solution" class="block text-sm font-medium text-white/60 mb-2">What Industry Solution are you interested in?</label>
                                    <select 
                                        id="industry-solution" 
                                        name="solution" 
                                        required
                                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue/50 transition-all">
                                        <option value="">Select an industry solution</option>
                                        <option value="enterprise" <%= typeof formData !== 'undefined' && formData.solution === 'enterprise' ? 'selected' : '' %>>Enterprise</option>
                                        <option value="government" <%= typeof formData !== 'undefined' && formData.solution === 'government' ? 'selected' : '' %>>Government</option>
                                        <option value="retail" <%= typeof formData !== 'undefined' && formData.solution === 'retail' ? 'selected' : '' %>>Retail</option>
                                        <option value="wholesale" <%= typeof formData !== 'undefined' && formData.solution === 'wholesale' ? 'selected' : '' %>>Wholesale Distribution</option>
                                        <option value="healthcare" <%= typeof formData !== 'undefined' && formData.solution === 'healthcare' ? 'selected' : '' %>>Healthcare</option>
                                        <option value="manufacturing" <%= typeof formData !== 'undefined' && formData.solution === 'manufacturing' ? 'selected' : '' %>>Manufacturing and Production</option>
                                        <option value="transportation" <%= typeof formData !== 'undefined' && formData.solution === 'transportation' ? 'selected' : '' %>>Transportation</option>
                                        <option value="others" <%= typeof formData !== 'undefined' && formData.solution === 'others' ? 'selected' : '' %>>Others</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <label for="industry-concern" class="block text-sm font-medium text-white/60 mb-2">Particular Concern</label>
                                <textarea 
                                    id="industry-concern" 
                                    name="concern" 
                                    rows="4" 
                                    required
                                    placeholder="Please describe your particular concerns or requirements..."
                                    class="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-white placeholder-white/20 focus:outline-none focus:border-tech-blue transition-colors"><%= typeof formData !== 'undefined' && formData.concern ? formData.concern : '' %></textarea>
                            </div>

                            <div class="flex justify-center pt-4">
                                <button 
                                    type="submit" 
                                    class="px-8 py-3 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-lg transition-all duration-300 shadow-lg shadow-tech-blue/20 transform hover:scale-105 hover:-translate-y-1 active:translate-y-0 flex items-center gap-2">
                                    <i data-lucide="send" class="w-5 h-5"></i>
                                    Submit Inquiry
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </div>
</main>

<!-- Form Toggle JavaScript -->
<script>
    function showServicesForm() {
        // Hide industry form
        document.getElementById('industry-inquiry-form').classList.add('hidden');
        
        // Show services form
        document.getElementById('services-inquiry-form').classList.remove('hidden');
        
        // Update button styles
        document.getElementById('services-inquiry-btn').className = 'px-8 py-4 bg-tech-blue text-white rounded-lg font-semibold transition-all duration-300 hover:bg-tech-blue/80 transform hover:scale-105 shadow-lg shadow-tech-blue/20';
        document.getElementById('industry-inquiry-btn').className = 'px-8 py-4 bg-white/10 text-white rounded-lg font-semibold transition-all duration-300 hover:bg-white/20 transform hover:scale-105 border border-white/20';
    }

    function showIndustryForm() {
        // Hide services form
        document.getElementById('services-inquiry-form').classList.add('hidden');
        
        // Show industry form
        document.getElementById('industry-inquiry-form').classList.remove('hidden');
        
        // Update button styles
        document.getElementById('industry-inquiry-btn').className = 'px-8 py-4 bg-tech-blue text-white rounded-lg font-semibold transition-all duration-300 hover:bg-tech-blue/80 transform hover:scale-105 shadow-lg shadow-tech-blue/20';
        document.getElementById('services-inquiry-btn').className = 'px-8 py-4 bg-white/10 text-white rounded-lg font-semibold transition-all duration-300 hover:bg-white/20 transform hover:scale-105 border border-white/20';
    }

    // Initialize with services form visible
    document.addEventListener('DOMContentLoaded', function() {
        showServicesForm();
        
        // Reinitialize Lucide icons for dynamically added content
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    });
</script>

<script>
    gsap.registerPlugin(ScrollTrigger);
    document.querySelectorAll('.reveal').forEach((el) => {
        gsap.from(el, {
            scrollTrigger: {
                trigger: el,
                start: "top 85%",
            },
            y: 40,
            opacity: 0,
            duration: 1,
            ease: "power3.out"
        });
    }); 
</script>

