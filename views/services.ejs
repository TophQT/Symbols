<%- include('partials/header') %>

<main class="pt-32 pb-24">
    <div class="container mx-auto px-6">
        <div class="text-center mb-20 space-y-4 reveal">
            <h1 class="text-5xl md:text-6xl font-bold font-grotesk">Services & Solutions</h1>
            <p class="text-white/60 max-w-2xl mx-auto">Expertise that drives digital transformation across industries.</p>
        </div>

        <div class="space-y-32">
            <!-- Service 1: Barcode Systems -->
            <div class="grid lg:grid-cols-2 gap-16 items-center reveal">
                <div class="relative group">
                    <div class="absolute -inset-4 bg-tech-blue/20 rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                    <div class="relative glass-card aspect-video rounded-3xl overflow-hidden flex items-center justify-center bg-tech-blue/5">
                        <i data-lucide="scan-barcode" class="w-32 h-32 text-tech-blue/20 group-hover:scale-110 transition-transform duration-700"></i>
                    </div>
                </div>
                <div class="space-y-8">
                    <h2 class="text-4xl font-bold font-grotesk">Advanced Barcode Systems</h2>
                    <p class="text-white/60 leading-relaxed text-lg">We design and implement custom barcode tracking systems that reduce human error and increase throughput. From hardware selection to backend integration, we handle the entire ecosystem.</p>
                    <ul class="space-y-4">
                        <li class="flex items-center space-x-3 text-white/80">
                            <i data-lucide="check-circle" class="text-tech-blue w-5 h-5"></i>
                            <span>Real-time inventory visibility</span>
                        </li>
                        <li class="flex items-center space-x-3 text-white/80">
                            <i data-lucide="check-circle" class="text-tech-blue w-5 h-5"></i>
                            <span>Custom barcode labeling strategies</span>
                        </li>
                        <li class="flex items-center space-x-3 text-white/80">
                            <i data-lucide="check-circle" class="text-tech-blue w-5 h-5"></i>
                            <span>Seamless ERP integration</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Service 2: Automation -->
            <div class="grid lg:grid-cols-2 gap-16 items-center reveal flex-row-reverse lg:flex-row-reverse">
                <div class="relative group">
                    <div class="absolute -inset-4 bg-tech-accent/20 rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                    <div class="relative glass-card aspect-video rounded-3xl overflow-hidden flex items-center justify-center bg-tech-accent/5">
                        <i data-lucide="cpu" class="w-32 h-32 text-tech-accent/20 group-hover:scale-110 transition-transform duration-700"></i>
                    </div>
                </div>
                <div class="space-y-8 lg:text-right">
                    <h2 class="text-4xl font-bold font-grotesk">Enterprise Automation</h2>
                    <p class="text-white/60 leading-relaxed text-lg">Automate repetitive tasks with our intelligent workflow solutions. We combine robotics and software to create highly efficient, autonomous operational environments.</p>
                    <ul class="space-y-4 inline-block text-left">
                        <li class="flex items-center space-x-3 text-white/80">
                            <i data-lucide="check-circle" class="text-tech-accent w-5 h-5"></i>
                            <span>Robotic Process Automation (RPA)</span>
                        </li>
                        <li class="flex items-center space-x-3 text-white/80">
                            <i data-lucide="check-circle" class="text-tech-accent w-5 h-5"></i>
                            <span>Automated Material Handling</span>
                        </li>
                        <li class="flex items-center space-x-3 text-white/80">
                            <i data-lucide="check-circle" class="text-tech-accent w-5 h-5"></i>
                            <span>Smart sorting and distribution</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    gsap.registerPlugin(ScrollTrigger);
    document.querySelectorAll('.reveal').forEach((el) => {
        gsap.from(el, {
            scrollTrigger: {
                trigger: el,
                start: "top 85%",
            },
            y: 40,
            opacity: 0,
            duration: 1,
            ease: "power3.out"
        });
    });
</script>

<%- include('partials/footer') %>
