<%- include('partials/header') %>

<main class="pt-32 pb-24">
    <div class="container mx-auto px-6">
        <!-- Page Title -->
        <div class="text-center mb-20 space-y-4 reveal">
            <h1 class="text-5xl md:text-7xl font-bold font-grotesk leading-tight">Our Brands</h1>
            <p class="text-white/60 max-w-2xl mx-auto text-lg">Discover the industry-leading brands we partner with to deliver cutting-edge technology solutions.</p>
            <div class="w-24 h-1 bg-tech-blue mx-auto rounded-full mt-8 opacity-50"></div>
        </div>

        <!-- Brands Sections -->
        <div class="space-y-8">
            <% if (brandsWeCarry && brandsWeCarry.length > 0) { %>
                <% brandsWeCarry.forEach((brand, index) => { %>
                    <!-- Brand Section -->
                    <section class="glass-card rounded-3xl p-8 md:p-12 reveal transition-all duration-500 border border-white/5 hover:border-tech-blue/30 relative overflow-hidden <%= index % 2 === 1 ? 'bg-white/[0.02]' : '' %>" data-delay="<%= index * 100 %>">
                        <!-- Background Glow Effect -->
                        <div class="absolute top-0 right-0 w-40 h-40 bg-tech-blue/5 rounded-full blur-3xl -mr-20 -mt-20 transition-colors"></div>
                        
                        <!-- Brand Content Container -->
                        <div class="relative z-10">
                            <!-- Desktop: Horizontal Layout -->
                            <div class="flex flex-col md:flex-row md:items-start md:gap-8 lg:gap-12">
                                <!-- Brand Logo -->
                                <div class="flex-shrink-0 mb-6 md:mb-0">
                                    <div class="w-32 h-32 bg-white/5 rounded-2xl flex items-center justify-center p-6 hover:scale-105 transition-transform duration-300">
                                        <img src="<%= brand.logo %>" alt="<%= brand.name %>" class="w-full h-full object-contain filter brightness-0 invert hover:brightness-100 transition-all duration-300">
                                    </div>
                                </div>
                                
                                <!-- Brand Info -->
                                <div class="flex-1 space-y-6">
                                    <!-- Brand Name -->
                                    <h2 class="text-3xl md:text-4xl font-bold font-grotesk text-white hover:text-tech-blue transition-colors duration-300">
                                        <%= brand.name %>
                                    </h2>
                                    
                                    <!-- Brand Description -->
                                    <div class="brand-description">
                                        <% if (brand.description) { %>
                                            <div class="description-content text-white/70 text-lg leading-relaxed">
                                                <p><%= brand.description %></p>
                                            </div>
                                        <% } else { %>
                                            <p class="text-white/50 text-lg leading-relaxed italic">
                                                Discover more about <%= brand.name %> and their innovative solutions.
                                            </p>
                                        <% } %>
                                    </div>
                                    
                                    <!-- Brand Products Button -->
                                    <div class="pt-4">
                                        <a href="/products?brand=<%= encodeURIComponent(brand.name) %>" class="inline-flex items-center space-x-3 px-8 py-4 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-xl transition-all duration-300 shadow-lg shadow-tech-blue/20 transform hover:scale-105 hover:-translate-y-1 active:translate-y-0 group">
                                            <span><%= brand.name %> Products</span>
                                            <i data-lucide="shopping-bag" class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-300"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Section Separator -->
                        <% if (index < brandsWeCarry.length - 1) { %>
                            <div class="absolute bottom-0 left-1/2 transform -translate-x-1/2 translate-y-full">
                                <div class="w-px h-8 bg-gradient-to-b from-white/10 to-transparent"></div>
                            </div>
                        <% } %>
                    </section>
                <% }); %>
            <% } else { %>
                <!-- Empty State -->
                <div class="col-span-full text-center py-20 glass-card rounded-3xl border-dashed reveal">
                    <div class="w-20 h-20 bg-white/5 rounded-2xl flex items-center justify-center mx-auto mb-6">
                        <i data-lucide="package" class="text-white/40 w-10 h-10"></i>
                    </div>
                    <h3 class="text-2xl font-bold font-grotesk text-white mb-4">No Brands Available</h3>
                    <p class="text-white/60 max-w-md mx-auto mb-8">
                        Our brand portfolio is currently being updated. Please check back soon to discover our trusted technology partners.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a href="/contact" class="inline-flex items-center space-x-2 px-6 py-3 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-lg transition-all duration-300 shadow-lg shadow-tech-blue/20 transform hover:scale-105">
                            <i data-lucide="mail" class="w-5 h-5"></i>
                            <span>Contact Us</span>
                        </a>
                        <a href="/" class="inline-flex items-center space-x-2 px-6 py-3 bg-white/10 hover:bg-white/20 text-white border border-white/20 rounded-lg transition-all duration-300">
                            <i data-lucide="home" class="w-5 h-5"></i>
                            <span>Back to Home</span>
                        </a>
                    </div>
                </div>
            <% } %>
        </div>

            <section id="inquiry" class="mt-24 reveal">
                <!-- Success/Error Messages -->
                <% if (success) { %>
                    <div class="mb-6 p-4 bg-green-500/20 border border-green-500/30 rounded-xl text-green-400 text-center font-medium">
                        <%= success %>
                    </div>
                <% } %>
                <% if (error) { %>
                    <div class="mb-6 p-4 bg-red-500/20 border border-red-500/30 rounded-xl text-red-400 text-center font-medium">
                        <%= error %>
                    </div>
                <% } %>
                
                <div class="glass-card p-10 md:p-12 rounded-2xl space-y-8 relative overflow-hidden w-full max-w-3xl mx-auto">
                    <!-- Glow decoration -->
                    <div class="absolute -top-32 -right-32 w-64 h-64 bg-tech-blue/10 rounded-full blur-[80px]"></div>

                    <div class="text-center mb-12">
                        <h2 class="text-4xl font-bold font-grotesk text-white mb-4">Products Inquiry</h2>
                        <p class="text-white/60 text-lg">Interested in our solutions? Fill out the form below and we'll get back to you shortly.</p>
                    </div>

                    <form id="productInquiryForm" method="POST" action="/product-inquiry" class="space-y-6">
                        <!-- Form Status Message -->
                        <div id="formStatus" class="hidden p-4 rounded-xl text-center font-medium transition-all duration-300"></div>

                        <!-- Contact Information -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label for="fullName" class="block text-sm font-medium text-white/70 ml-1">Full Name</label>
                                <input type="text" id="fullName" name="fullName" required
                                    class="w-full px-5 py-3.5 bg-white/5 border border-white/10 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue transition-all duration-300"
                                    placeholder="John Doe">
                            </div>
                            <div class="space-y-2">
                                <label for="email" class="block text-sm font-medium text-white/70 ml-1">Email Address</label>
                                <input type="email" id="email" name="email" required
                                    class="w-full px-5 py-3.5 bg-white/5 border border-white/10 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue transition-all duration-300"
                                    placeholder="john@example.com">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label for="contactNumber" class="block text-sm font-medium text-white/70 ml-1">Contact Number</label>
                            <input type="tel" id="contactNumber" name="contactNumber" required
                                class="w-full px-5 py-3.5 bg-white/5 border border-white/10 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue transition-all duration-300"
                                placeholder="+1 (555) 000-0000">
                        </div>

                        <!-- Brand Selection -->
                        <div class="space-y-4">
                            <label class="block text-sm font-medium text-white/70 ml-1">Brands Interested In</label>
                            <div class="relative" id="brandDropdownContainer">
                                <button type="button" id="brandDropdownBtn" 
                                    class="w-full flex items-center justify-between px-5 py-3.5 bg-white/5 border border-white/10 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue transition-all duration-300">
                                    <span id="selectedBrandsText" class="text-white/40 truncate">Select brands...</span>
                                    <i data-lucide="chevron-down" class="w-5 h-5 text-white/40 transition-transform duration-300" id="dropdownIcon"></i>
                                </button>
                                
                                <div id="brandDropdownMenu" 
                                    class="hidden absolute z-50 left-0 right-0 mt-2 bg-tech-dark border border-white/10 rounded-xl shadow-2xl overflow-hidden max-h-60 overflow-y-auto custom-scrollbar backdrop-blur-xl">
                                    <div class="p-2 space-y-1">
                                        <% if (brandsWeCarry && brandsWeCarry.length > 0) { %>
                                            <% brandsWeCarry.forEach(brand => { %>
                                                <label class="flex items-center space-x-3 p-3 hover:bg-white/5 rounded-lg cursor-pointer transition-colors group">
                                                    <input type="checkbox" name="brands" value="<%= brand.name %>" 
                                                        class="brand-checkbox w-4 h-4 rounded border-white/20 bg-white/5 text-tech-blue focus:ring-tech-blue focus:ring-offset-0 transition-all duration-300 cursor-pointer">
                                                    <span class="text-sm text-white/70 group-hover:text-tech-blue transition-colors"><%= brand.name %></span>
                                                </label>
                                            <% }); %>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Message -->
                        <div class="space-y-2">
                            <label for="message" class="block text-sm font-medium text-white/70 ml-1">Message</label>
                            <textarea id="message" name="message" rows="4" required
                                class="w-full px-5 py-3.5 bg-white/5 border border-white/10 rounded-xl text-white focus:outline-none focus:ring-2 focus:ring-tech-blue/50 focus:border-tech-blue transition-all duration-300 resize-none"
                                placeholder="Tell us about your project..."></textarea>
                        </div>

                        <!-- Submit Button -->
                        <div class="pt-4">
                            <button type="submit" id="submitBtn"
                                class="w-full inline-flex items-center justify-center space-x-3 px-8 py-4 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-xl transition-all duration-300 shadow-lg shadow-tech-blue/20 transform hover:scale-[1.02] active:scale-100 group">
                                <span>Send Inquiry</span>
                                <i data-lucide="send" class="w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        </div>
</main>

<!-- Custom Styles for Brand Sections -->
<style>
    /* Alternating background colors for sections */
    .brand-section:nth-child(even) {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.02) 0%, rgba(59, 130, 246, 0.05) 100%);
    }
    
    .brand-section:nth-child(odd) {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, rgba(255, 255, 255, 0.05) 100%);
    }
    
    /* Light mode adjustments for brand logos */
    body.light .filter.brightness-0.invert {
        filter: none !important;
    }
    
    body.light .filter.brightness-0.invert:hover {
        filter: brightness(1.1) !important;
    }
    
    /* Enhanced hover effects */
    .brand-section {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .brand-section:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px rgba(59, 130, 246, 0.1);
    }
    
    /* Responsive typography */
    @media (max-width: 768px) {
        .brand-section h2 {
            font-size: 2rem;
            line-height: 1.2;
        }
        
        .brand-description .description-content {
            font-size: 1rem;
        }
    }

    /* Custom scrollbar for dropdown */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: var(--tech-bg);
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: var(--tech-card-border);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #3b82f6;
    }
</style>

<!-- GSAP Animations + Read More Functionality -->
<script>
    gsap.registerPlugin(ScrollTrigger);
    
    // GSAP Animations for reveal elements
    document.querySelectorAll('.reveal').forEach((el) => {
        const delay = el.dataset.delay ? parseInt(el.dataset.delay) : 0;
        gsap.from(el, {
            scrollTrigger: {
                trigger: el,
                start: "top 85%",
                toggleActions: "play none none none"
            },
            y: 50,
            opacity: 0,
            duration: 1,
            delay: delay / 1000,
            ease: "power3.out"
        });
    });
    
    // Read More functionality removed - descriptions now fully visible
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize Lucide icons
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
        
        // Multi-select dropdown logic
        const dropdownBtn = document.getElementById('brandDropdownBtn');
        const dropdownMenu = document.getElementById('brandDropdownMenu');
        const dropdownIcon = document.getElementById('dropdownIcon');
        const selectedText = document.getElementById('selectedBrandsText');
        const checkboxes = document.querySelectorAll('.brand-checkbox');

        if (dropdownBtn && dropdownMenu) {
            dropdownBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                dropdownMenu.classList.toggle('hidden');
                dropdownIcon.classList.toggle('rotate-180');
            });

            // Update text based on selection
            const updateSelectedText = () => {
                const selected = Array.from(checkboxes)
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);
                
                if (selected.length === 0) {
                    selectedText.textContent = 'Select brands...';
                    selectedText.classList.add('text-white/40');
                } else {
                    selectedText.textContent = selected.join(', ');
                    selectedText.classList.remove('text-white/40');
                }
            };

            checkboxes.forEach(cb => {
                cb.addEventListener('change', updateSelectedText);
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', (e) => {
                if (!dropdownMenu.contains(e.target) && !dropdownBtn.contains(e.target)) {
                    dropdownMenu.classList.add('hidden');
                    dropdownIcon.classList.remove('rotate-180');
                }
            });
        }
        
        // Enhanced hover animations for brand sections
        const brandSections = document.querySelectorAll('section[data-delay]');
        brandSections.forEach((section, index) => {
            section.addEventListener('mouseenter', function() {
                gsap.to(this, {
                    y: -4,
                    duration: 0.3,
                    ease: "power2.out"
                });
            });
            
            section.addEventListener('mouseleave', function() {
                gsap.to(this, {
                    y: 0,
                    duration: 0.3,
                    ease: "power2.out"
                });
            });
        });
        
        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Form Submission Logic
        const inquiryForm = document.getElementById('productInquiryForm');
        const formStatus = document.getElementById('formStatus');
        const submitBtn = document.getElementById('submitBtn');

        if (inquiryForm) {
            inquiryForm.addEventListener('submit', function(e) {
                // Reset status
                formStatus.classList.remove('hidden', 'bg-green-500/20', 'text-green-400', 'bg-red-500/20', 'text-red-400');
                formStatus.classList.add('bg-tech-blue/20', 'text-tech-blue');
                formStatus.textContent = 'Sending inquiry...';
                formStatus.classList.remove('hidden');
                
                submitBtn.disabled = true;
                submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
                
                // Allow form to submit normally
                // The form will handle the redirect and success message via the backend
            });
        }
    });
</script>

<%- include('partials/footer') %>
