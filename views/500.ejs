<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'tech-dark': '#0b0e14',
              'tech-blue': '#3b82f6',
              'tech-accent': '#60a5fa',
              'tech-red': '#ef4444',
            }
          }
        }
      }
    </script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap');
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: #0b0e14;
        color: #ffffff;
      }
      
      .font-grotesk {
        font-family: 'Space Grotesk', sans-serif;
      }
    </style>
</head>
<body class="bg-tech-dark text-white min-h-screen flex items-center justify-center">
    <div class="text-center space-y-6">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-tech-red/10 rounded-full">
            <i data-lucide="alert-triangle" class="w-10 h-10 text-tech-red"></i>
        </div>
        <h1 class="text-4xl font-bold font-grotesk">500 - Server Error</h1>
        <p class="text-white/60 max-w-md">Something went wrong on our end. Please try again later.</p>
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-tech-blue hover:bg-blue-600 text-white rounded-lg transition-colors">
            <i data-lucide="home" class="w-4 h-4"></i>
            Back to Home
        </a>
    </div>
    <script>
        lucide.createIcons();
    </script>
</body>
</html>
