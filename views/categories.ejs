<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'tech-dark': '#0b0e14',
              'tech-blue': '#3b82f6',
              'tech-accent': '#60a5fa',
              'tech-red': '#ef4444',
            }
          }
        }
      }
    </script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap');
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: #0b0e14;
        color: #ffffff;
        transition: background-color 0.3s ease, color 0.3s ease;
      }
      
      /* Light Mode Styles */
      body.light {
        background-color: #ffffff;
        color: #1f2937;
      }
      
      body.light .glass {
        background: rgba(31, 41, 55, 0.05);
        border: 1px solid rgba(31, 41, 55, 0.1);
      }
      
      body.light .glass-card {
        background: rgba(31, 41, 55, 0.03);
        border: 1px solid rgba(31, 41, 55, 0.08);
      }
      
      body.light .glass-card:hover {
        background: rgba(31, 41, 55, 0.05);
        border-color: rgba(59, 130, 246, 0.2);
      }
      
      body.light .text-white {
        color: #1f2937 !important;
      }
      
      body.light .text-white\/40 {
        color: rgba(31, 41, 55, 0.4) !important;
      }
      
      body.light .text-white\/60 {
        color: rgba(31, 41, 55, 0.6) !important;
      }
      
      body.light .text-white\/80 {
        color: rgba(31, 41, 55, 0.8) !important;
      }
      
      body.light .bg-white\/5 {
        background-color: rgba(31, 41, 55, 0.05) !important;
      }
      
      body.light .bg-white\/10 {
        background-color: rgba(31, 41, 55, 0.1) !important;
      }
      
      body.light .border-white\/5 {
        border-color: rgba(31, 41, 55, 0.05) !important;
      }
      
      body.light .border-white\/10 {
        border-color: rgba(31, 41, 55, 0.1) !important;
      }
      
      body.light .bg-tech-blue\/10 {
        background-color: rgba(59, 130, 246, 0.1) !important;
      }
      
      body.light .bg-tech-blue\/20 {
        background-color: rgba(59, 130, 246, 0.2) !important;
      }
      
      body.light .border-tech-blue\/20 {
        border-color: rgba(59, 130, 246, 0.2) !important;
      }
      
      body.light .border-tech-blue\/30 {
        border-color: rgba(59, 130, 246, 0.3) !important;
      }
      
      body.light #theme-toggle {
        background-color: rgba(31, 41, 55, 0.1);
        border-color: rgba(31, 41, 55, 0.2);
      }
      
      body.light #theme-toggle .bg-white {
        background-color: #f3f4f6;
      }
      
      /* Theme toggle active state */
      #theme-toggle.active {
        background-color: rgba(59, 130, 246, 0.2);
      }
      
      #theme-toggle.active .bg-white {
        transform: translateX(28px);
      }
      
      .font-grotesk {
        font-family: 'Space Grotesk', sans-serif;
      }

      .glass {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .glass-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.3s ease;
      }

      .glass-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(59, 130, 246, 0.3);
        transform: translateY(-5px);
        box-shadow: 0 10px 30px -10px rgba(59, 130, 246, 0.2);
      }

      /* Light mode input styles */
      body.light input,
      body.light select,
      body.light textarea {
        color: #1f2937;
        background-color: rgba(31, 41, 55, 0.05);
        border-color: rgba(31, 41, 55, 0.1);
      }

      body.light input::placeholder,
      body.light textarea::placeholder {
        color: rgba(31, 41, 55, 0.4);
      }

      body.light input:focus,
      body.light select:focus,
      body.light textarea:focus {
        background-color: rgba(31, 41, 55, 0.1);
        border-color: #3b82f6;
      }

      /* Light mode link styles */
      body.light a.glass-card {
        background: rgba(31, 41, 55, 0.03);
        border-color: rgba(31, 41, 55, 0.08);
      }

      body.light a.glass-card:hover {
        background: rgba(31, 41, 55, 0.05);
        border-color: rgba(59, 130, 246, 0.2);
      }

      body.light a.glass-card.border-tech-blue\/30 {
        border-color: rgba(59, 130, 246, 0.3);
        background: rgba(59, 130, 246, 0.05);
      }

      body.light .text-tech-blue {
        color: #3b82f6;
      }

      body.light .bg-tech-blue\/5 {
        background-color: rgba(59, 130, 246, 0.05);
      }
    </style>
</head>
<body class="bg-tech-dark text-white">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-64 glass border-r border-white/5 hidden md:flex flex-col fixed h-screen z-40">
            <div class="p-6">
               <a href="/" class="flex items-center group mb-8">
                    <% if (locals.settings && locals.settings.logo) { %>
                        <img src="<%= settings.logo %>" alt="Logo" class="h-10 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                    <% } else if (locals.settings && locals.settings.defaultLogo) { %>
                        <img src="<%= settings.defaultLogo %>" alt="Default Logo" class="h-10 w-auto object-contain transform group-hover:scale-110 transition-transform duration-300">
                    <% } else { %>
                        <div class="h-10 w-auto flex items-center justify-center transform group-hover:scale-110 transition-transform duration-300">
                            <i data-lucide="scan-barcode" class="text-tech-blue w-7 h-7"></i>
                        </div>
                    <% } %>
                </a>
                <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-tech-blue/10 border border-tech-blue/20 text-tech-blue text-[10px] font-bold uppercase tracking-widest mb-4">
                    <span class="w-2 h-2 rounded-full bg-tech-blue"></span>
                    <span>System Online</span>
                </div>
            </div>
            <nav class="flex-grow space-y-1 px-4">
                <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                    <i data-lucide="layout-dashboard" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                    <span class="font-medium">Dashboard</span>
                </a>
                <div class="space-y-1">
                    <a href="/admin/products/brands" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="bookmark" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Brands</span>
                    </a>
                    <a href="/admin/products/categories" class="flex items-center gap-3 px-4 py-3 bg-tech-blue/10 text-tech-blue border border-tech-blue/20 rounded-xl transition-all">
                        <i data-lucide="folder" class="w-5 h-5"></i>
                        <span class="font-medium">Categories</span>
                    </a>
                    <a href="/admin/products" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="shopping-bag" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Products</span>
                    </a>
                    <a href="/admin/brandswecarry" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="image" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Brands We Carry</span>
                    </a>
                    <a href="/admin/software" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="package" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Software</span>
                    </a>    
                    <a href="/admin/updates" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="rss" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Updates</span>
                    </a>
                    <a href="/admin/customers" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="users" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Customers</span>
                    </a>
                    <a href="/admin/product-inquiries" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                        <i data-lucide="mail" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                        <span class="font-medium">Products Inquiry</span>
                    </a>
                </div>
                <a href="/admin/settings" class="flex items-center gap-3 px-4 py-3 text-white/60 hover:text-white hover:bg-white/5 rounded-xl transition-all group">
                    <i data-lucide="settings" class="w-5 h-5 group-hover:text-tech-blue transition-colors"></i>
                    <span class="font-medium">Settings</span>
                </a>
            </nav>
            <div class="p-4 mt-auto">
                <a href="/admin/logout" class="flex items-center gap-3 px-4 py-3 text-tech-red hover:bg-tech-red/10 rounded-xl transition-all group">
                    <i data-lucide="log-out" class="w-5 h-5"></i>
                    <span class="font-medium">Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-grow md:ml-64 p-6 lg:p-10">
            <!-- Header -->
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
                <div class="space-y-1">
                    <h1 class="text-3xl font-bold font-grotesk text-white">Product Categories</h1>
                    <p class="text-white/40 text-xs">Manage categories</p>
                </div>
                <div class="flex items-center gap-3">
                    <!-- Theme Toggle - Fixed icon display -->
                    <button id="theme-toggle" class="relative w-14 h-7 bg-white/10 border border-white/20 rounded-full transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-tech-blue/50">
                        <div class="absolute top-0.5 left-0.5 w-6 h-6 bg-white rounded-full shadow-md transform transition-transform duration-300 flex items-center justify-center">
                            <i data-lucide="sun" class="w-3 h-3 text-tech-blue"></i>
                            <i data-lucide="moon" class="w-3 h-3 text-tech-blue hidden"></i>
                        </div>
                    </button>
                    <div class="flex items-center gap-3 bg-white/5 border border-white/10 p-2 rounded-2xl pr-6">
                        <div class="w-12 h-12 rounded-xl bg-tech-blue/20 flex items-center justify-center text-tech-blue font-bold border border-tech-blue/30 shadow-lg shadow-tech-blue/10">
                            A
                        </div>
                        <div>
                            <p class="text-sm font-bold text-white leading-none">Admin User</p>
                            <p class="text-[10px] text-white/40 uppercase tracking-widest mt-1">Super Admin</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Success/Error Messages -->
            <% if (success) { %>
                <div class="mb-6 p-4 bg-green-500/10 border border-green-500/20 rounded-xl text-green-400 flex items-center gap-3">
                    <i data-lucide="check-circle" class="w-5 h-5"></i>
                    <span><%= success %></span>
                </div>
            <% } %>
            <% if (error) { %>
                <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 flex items-center gap-3">
                    <i data-lucide="alert-circle" class="w-5 h-5"></i>
                    <span><%= error %></span>
                </div>
            <% } %>

            <!-- Add Category Form -->
            <div class="glass-card rounded-3xl p-8 border border-white/5 mb-10">
                <h2 class="text-xl font-bold font-grotesk text-white mb-6">Product Categories</h2>
                
                <!-- Brand Selection -->
                <div class="mb-8">
                    <label class="block text-xs font-medium text-white/80 mb-3">Select Brand</label>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                        <% brands.forEach(brand => { %>
                            <a href="/admin/products/categories?brand=<%= brand._id %>" 
                               class="glass-card p-4 rounded-xl border border-white/5 hover:border-tech-blue/30 transition-all group <%= selectedBrand && selectedBrand._id.toString() === brand._id.toString() ? 'border-tech-blue/30 bg-tech-blue/5' : '' %>">
                                <div class="flex flex-col items-center text-center">
                                    <div class="w-20 h-20 bg-white/5 rounded-xl overflow-hidden flex items-center justify-center group-hover:scale-110 transition-transform">
                                        <img src="<%= brand.logo %>" alt="<%= brand.description %>" class="w-full h-full object-contain p-2">
                                    </div>
                                    <% if (selectedBrand && selectedBrand._id.toString() === brand._id.toString()) { %>
                                        <span class="px-2 py-1 bg-tech-blue/10 border border-tech-blue/20 text-tech-blue text-xs rounded-full mt-2">Selected</span>
                                    <% } %>
                                </div>
                            </a>
                        <% }); %>
                        <% if (brands.length === 0) { %>
                            <div class="col-span-full text-center py-8">
                                <p class="text-white/40 text-sm">No brands found. <a href="/admin/products/brands" class="text-tech-blue hover:underline">Create a brand first</a></p>
                            </div>
                        <% } %>
                    </div>
                </div>

                <% if (selectedBrand) { %>
                    <!-- Category Creation Form -->
                    <div class="border-t border-white/10 pt-8">
                        <h3 class="text-base font-semibold text-white mb-3 flex items-center gap-2">
                            <i data-lucide="folder-plus" class="w-4 h-4 text-tech-blue"></i>
                            <%= selectedBrand.name %>
                        </h3>
                        <form action="/admin/products/categories" method="POST" class="space-y-6">
                            <input type="hidden" name="brand" value="<%= selectedBrand._id %>">
                            <div class="grid md:grid-cols-1 gap-6">
                                <div>
                                    <label class="block text-xs font-medium text-white/80 mb-1">Category Name</label>
                                    <input type="text" name="name" required class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-white/40 focus:outline-none focus:border-tech-blue/50 focus:bg-white/10 transition-all" placeholder="Enter category name...">
                                </div>
                            </div>
                            <div class="flex justify-end">
                                <button type="submit" class="px-6 py-3 bg-tech-blue hover:bg-tech-blue/80 text-white font-medium rounded-xl transition-all transform hover:scale-105 flex items-center gap-2">
                                    <i data-lucide="plus" class="w-4 h-4"></i>
                                    Add Category
                                </button>
                            </div>
                        </form>
                    </div>
                <% } else { %>
                    <!-- No Brand Selected Message -->
                    <div class="border-t border-white/10 pt-8">
                        <div class="text-center py-12">
                            <i data-lucide="mouse-pointer-click" class="w-16 h-16 text-white/20 mx-auto mb-4"></i>
                            <p class="text-white/40 text-sm mb-1">Select a Brand</p>
                            <p class="text-white/20 text-xs">Choose a brand to manage categories</p>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Categories List -->
            <div class="space-y-6">
                <% if (selectedBrand) { %>
                    <h2 class="text-xl font-bold font-grotesk text-white"><%= selectedBrand.name %></h2>
                <% } else { %>
                    <h2 class="text-xl font-bold font-grotesk text-white">All Categories</h2>
                <% } %>
                <% if (categories.length === 0) { %>
                    <div class="glass-card rounded-3xl p-12 border border-white/5 text-center">
                        <i data-lucide="folder" class="w-16 h-16 text-white/20 mx-auto mb-4"></i>
                        <% if (selectedBrand) { %>
                            <p class="text-white/40 text-sm">No categories for <%= selectedBrand.name %></p>
                            <p class="text-white/20 text-xs mt-1">Create the first category</p>
                        <% } else { %>
                            <p class="text-white/40 text-sm">No categories found</p>
                            <p class="text-white/20 text-xs mt-1">Select a brand to view categories</p>
                        <% } %>
                    </div>
                <% } else { %>
                    <div class="glass-card rounded-2xl p-6 border border-white/5">
                        <table class="w-full">
                            <thead>
                                <tr class="border-b border-white/10">
                                    <th class="text-left py-3 px-4 text-white/60 text-xs font-medium">Category Name</th>
                                    <th class="text-left py-3 px-4 text-white/60 text-xs font-medium">Brand</th>
                                    <th class="text-left py-3 px-4 text-white/60 text-xs font-medium">Created</th>
                                    <th class="text-right py-3 px-4 text-white/60 text-xs font-medium">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% categories.forEach(category => { %>
                                    <tr class="border-b border-white/5 hover:bg-white/5 transition-all">
                                        <td class="py-3 px-4">
                                            <div class="flex items-center gap-3">
                                                <div class="w-8 h-8 bg-tech-blue/10 rounded-lg flex items-center justify-center text-tech-blue">
                                                    <i data-lucide="folder" class="w-4 h-4"></i>
                                                </div>
                                                <span class="text-white font-medium"><%= category.name %></span>
                                            </div>
                                        </td>
                                        <td class="py-3 px-4">
                                            <% if (category.brand) { %>
                                                <span class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-white/60">
                                                    <%= category.brand.name %>
                                                </span>
                                            <% } else { %>
                                                <span class="text-white/40 text-xs">No Brand</span>
                                            <% } %>
                                        </td>
                                        <td class="py-3 px-4 text-white/40 text-xs">
                                            <%= new Date(category.createdAt).toLocaleDateString() %>
                                        </td>
                                        <td class="py-3 px-4 text-right">
                                            <form action="/admin/products/categories/<%= category._id %>/delete" method="POST" class="inline-flex justify-end" onsubmit="return confirm('Are you sure you want to delete this category? This action cannot be undone.')">
                                                <button type="submit" class="px-3 py-1 bg-tech-red/10 hover:bg-tech-red/20 text-tech-red text-xs font-medium rounded-lg transition-all flex items-center gap-1">
                                                    <i data-lucide="trash-2" class="w-3 h-3"></i>
                                                    Delete
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </main>
    </div>
    <script>
        lucide.createIcons();
        
        // Theme Toggle Functionality
        const themeToggle = document.getElementById('theme-toggle');
        const body = document.body;
        
        // Check for saved theme preference or default to dark mode
        const savedTheme = localStorage.getItem('dashboard-theme') || 'dark';
        body.classList.toggle('light', savedTheme === 'light');
        themeToggle.classList.toggle('active', savedTheme === 'light');
        
        // Update icon visibility based on theme
        const updateIcons = () => {
            const sunIcon = document.querySelector('#theme-toggle [data-lucide="sun"]');
            const moonIcon = document.querySelector('#theme-toggle [data-lucide="moon"]');
            if (sunIcon && moonIcon) {
                if (body.classList.contains('light')) {
                    // Light mode - show sun, hide moon
                    sunIcon.classList.remove('hidden');
                    moonIcon.classList.add('hidden');
                } else {
                    // Dark mode - show moon, hide sun
                    sunIcon.classList.add('hidden');
                    moonIcon.classList.remove('hidden');
                }
            }
        };
        
        // Initial icon update
        updateIcons();
        
        // Theme toggle event listener
        themeToggle.addEventListener('click', () => {
            const isLight = body.classList.toggle('light');
            themeToggle.classList.toggle('active', isLight);
            
            // Save theme preference
            localStorage.setItem('dashboard-theme', isLight ? 'light' : 'dark');
            
            // Update icons
            updateIcons();
        });
    </script>
</body>
</html>
