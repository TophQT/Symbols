<%- include('partials/header') %>

<main class="pt-32 pb-24 min-h-screen" style="background-color: #0b0e14;">
    <div class="container mx-auto px-6">
        <!-- Page Header -->
        <div class="text-center mb-16 space-y-4">
            <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-tech-blue/10 border border-tech-blue/20 text-tech-blue text-xs font-bold uppercase tracking-widest">
                <span class="w-2 h-2 rounded-full bg-tech-blue"></span>
                <span>Our Catalog</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-bold font-grotesk tracking-tight">
                Advanced <span class="text-transparent bg-clip-text bg-gradient-to-r from-tech-blue to-tech-accent">Technology</span> Solutions
            </h1>
            <p class="text-white/60 max-w-2xl mx-auto text-lg">
                Browse our complete range of professional hardware and enterprise software solutions.
            </p>
        </div>

        <!-- Filters Section -->
        <div class="space-y-8 mb-16">
            <!-- Brand Filters -->
            <div class="space-y-4">
                <h3 class="text-sm font-bold uppercase tracking-widest text-white/40 flex items-center gap-2">
                    <i data-lucide="award" class="w-4 h-4"></i> Filter by Brand
                </h3>
                <div class="flex flex-wrap items-center gap-3">
                    <a href="/products?brand=all&category=<%= selectedCategory %>" 
                       class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all border <%= selectedBrand === 'all' ? 'bg-tech-blue border-tech-blue text-white shadow-lg shadow-tech-blue/20' : 'bg-white/5 border-white/10 text-white/60 hover:bg-white/10 hover:text-white hover:border-white/20' %>">
                        All Brands
                    </a>
                    <% brands.forEach(brand => { %>
                        <a href="/products?brand=<%= brand._id %>&category=<%= selectedCategory %>" 
                           class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all border <%= selectedBrand === brand._id.toString() ? 'bg-tech-blue border-tech-blue text-white shadow-lg shadow-tech-blue/20' : 'bg-white/5 border-white/10 text-white/60 hover:bg-white/10 hover:text-white hover:border-white/20' %>">
                            <%= brand.name %>
                        </a>
                    <% }) %>
                </div>
            </div>

            <!-- Category Filters -->
            <div class="space-y-4">
                <h3 class="text-sm font-bold uppercase tracking-widest text-white/40 flex items-center gap-2">
                    <i data-lucide="layers" class="w-4 h-4"></i> Filter by Category
                </h3>
                <div class="flex flex-wrap items-center gap-3">
                    <a href="/products?brand=<%= selectedBrand %>&category=all" 
                       class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all border <%= selectedCategory === 'all' ? 'bg-tech-blue border-tech-blue text-white shadow-lg shadow-tech-blue/20' : 'bg-white/5 border-white/10 text-white/60 hover:bg-white/10 hover:text-white hover:border-white/20' %>">
                        All Categories
                    </a>
                    <% categories.forEach(category => { %>
                        <a href="/products?brand=<%= selectedBrand %>&category=<%= category._id %>" 
                           class="px-6 py-2.5 rounded-xl text-sm font-bold transition-all border <%= selectedCategory === category._id.toString() ? 'bg-tech-blue border-tech-blue text-white shadow-lg shadow-tech-blue/20' : 'bg-white/5 border-white/10 text-white/60 hover:bg-white/10 hover:text-white hover:border-white/20' %>">
                            <%= category.name %>
                        </a>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <% if (products && products.length > 0) { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                <% products.forEach((product, index) => { %>
                    <div class="glass-card group rounded-3xl overflow-hidden flex flex-col h-full hover:-translate-y-2 transition-all duration-500 reveal" style="transition-delay: <%= (index % 4) * 100 %>ms">
                        <!-- Product Image Container -->
                        <div class="aspect-square relative overflow-hidden bg-white/2">
                            <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-contain p-8 group-hover:scale-110 transition-transform duration-700">
                            
                            <!-- Badges -->
                            <div class="absolute top-4 left-4 flex flex-col gap-2">
                                <span class="px-3 py-1 rounded-lg bg-tech-blue/90 backdrop-blur-md text-[10px] font-bold uppercase tracking-widest text-white shadow-lg">
                                    <%= product.brand.name %>
                                </span>
                            </div>
                        </div>

                        <!-- Product Info -->
                        <div class="p-6 flex flex-col flex-grow space-y-4">
                            <div class="space-y-1 flex-grow">
                                <span class="text-[10px] font-bold uppercase tracking-widest text-white/40">
                                    <%= product.category.name %>
                                </span>
                                <h3 class="text-xl font-bold font-grotesk text-white group-hover:text-tech-blue transition-colors line-clamp-2">
                                    <%= product.name %>
                                </h3>
                            </div>
                            
                            <a href="/contact?product=<%= encodeURIComponent(product.name) %>" class="w-full py-3 bg-white/5 group-hover:bg-tech-blue text-white text-sm font-bold rounded-xl border border-white/10 group-hover:border-tech-blue transition-all duration-300 flex items-center justify-center gap-2">
                                <i data-lucide="mail" class="w-4 h-4"></i>
                                Inquire Now
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="py-24 flex flex-col items-center justify-center space-y-6 glass-card rounded-3xl border-dashed">
                <div class="w-20 h-20 rounded-2xl bg-white/5 flex items-center justify-center text-white/20">
                    <i data-lucide="package-search" class="w-10 h-10"></i>
                </div>
                <div class="text-center space-y-2">
                    <h3 class="text-2xl font-bold font-grotesk text-white">No products found</h3>
                    <p class="text-white/40">Try adjusting your filters to find what you're looking for.</p>
                </div>
                <a href="/products" class="px-8 py-3 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-xl transition-all shadow-lg shadow-tech-blue/20">
                    Clear All Filters
                </a>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>

<script>
    // Initialize Lucide icons
    lucide.createIcons();

    // Intersection Observer for scroll animations
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('opacity-100', 'translate-y-0');
                entry.target.classList.remove('opacity-0', 'translate-y-8');
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach(el => {
        el.classList.add('opacity-0', 'translate-y-8', 'transition-all', 'duration-700', 'ease-out');
        observer.observe(el);
    });
</script>
