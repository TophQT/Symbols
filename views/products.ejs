<%- include('partials/header') %>

<main class="pt-32 pb-24 min-h-screen bg-tech-dark relative overflow-hidden">
    <!-- Decorative Background Elements -->
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-tech-blue/5 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-tech-accent/5 rounded-full blur-[150px]"></div>
        <div class="absolute top-1/2 left-0 w-64 h-64 bg-purple-500/5 rounded-full blur-[100px]"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10">
        <!-- Page Header & Prominent Selected Brand Logo -->
        <div class="text-center mb-20 space-y-8">
            <div class="inline-flex items-center space-x-2 px-3 py-1 rounded-full bg-tech-blue/10 border border-tech-blue/20 text-tech-blue text-xs font-bold uppercase tracking-widest reveal">
                <span class="w-2 h-2 rounded-full bg-tech-blue animate-pulse"></span>
                <span>Our Products</span>
            </div>
            
            <% if (selectedBrandObject) { %>
                <!-- Prominent Selected Brand Logo -->
                <div class="flex flex-col items-center space-y-6 reveal">
                    <div class="group relative">
                        <div class="absolute -inset-4 bg-tech-blue/20 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        <div class="relative w-32 h-32 md:w-48 md:h-48 flex items-center justify-center">
                            <img src="<%= selectedBrandObject.logo %>" alt="<%= selectedBrandObject.name %>" class="max-w-full max-h-full object-contain">
                        </div>
                    </div>
                    <h1 class="text-4xl md:text-6xl font-bold font-grotesk tracking-tight text-white leading-tight">
                        <%= selectedBrandObject.name %> <span class="text-transparent bg-clip-text bg-gradient-to-r from-tech-blue to-tech-accent">Products</span>
                    </h1>
                </div>
<% } else { %>
                <div class="space-y-4 reveal">
                    <h1 class="text-5xl md:text-8xl font-bold font-grotesk tracking-tight leading-tight">
                        Advanced <span class="text-transparent bg-clip-text bg-gradient-to-r from-tech-blue to-tech-accent">Enterprise</span><br>
                        Technology <span class="text-white">Catalog</span>
                    </h1>
                </div>
            <% } %>
            
            <p class="text-white/60 max-w-2xl mx-auto text-lg md:text-xl leading-relaxed reveal">
                Explore our curated collection of mission-critical hardware and intelligent software ecosystems designed for modern industry.
            </p>
        </div>

        <!-- Filters Section -->
        <div class="space-y-12 mb-20">
            <!-- Search Bar -->
            <div class="max-w-2xl mx-auto reveal">
                <form action="/products" method="GET" class="relative group">
                    <!-- Hidden fields for current filters -->
                    <input type="hidden" name="brand" value="<%= selectedBrand %>">
                    <input type="hidden" name="category" value="<%= selectedCategory %>">
                    
                    <input type="text" 
                           name="search" 
                           value="<%= search %>"
                           placeholder="Search for hardware or software solutions..." 
                           class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-16 pr-6 focus:outline-none focus:border-tech-blue focus:bg-white/10 transition-all glass">
                    
                    <div class="absolute inset-y-0 left-6 flex items-center pointer-events-none z-10">
                        <i data-lucide="search" class="w-5 h-5 text-white group-focus-within:text-tech-blue transition-all duration-300"></i>
                    </div>
                    
                    <% if (search) { %>
                        <a href="/products?brand=<%= selectedBrand %>&category=<%= selectedCategory %>" 
                           class="absolute inset-y-0 right-4 flex items-center px-2 text-white hover:text-tech-blue transition-colors z-10">
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </a>
                    <% } %>
                </form>
            </div>

            <!-- Brand Filters -->
            <div class="space-y-6 reveal">
                <div class="flex items-center justify-between px-2">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-white/40 flex items-center gap-2">
                        <i data-lucide="award" class="w-4 h-4 text-tech-blue"></i> Filter by Brand
                    </h3>
                    <% if (selectedBrand !== 'all') { %>
                        <a href="/products?brand=all&category=all" class="text-[10px] font-bold uppercase tracking-widest text-tech-blue hover:text-tech-accent transition-colors">Clear All</a>
                    <% } %>
                </div>
                
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 p-6 bg-white/2 rounded-[2.5rem] border border-white/5 glass">
                    <!-- All Brands Button -->
                    <a href="/products?brand=all&category=<%= selectedCategory %>" 
                       class="group relative p-4 rounded-2xl transition-all duration-300 flex flex-col items-center justify-center gap-3 <%= selectedBrand === 'all' ? 'bg-tech-blue/20 border border-tech-blue/30' : 'bg-white/5 border border-white/5 hover:bg-white/10' %>">
                        <div class="w-10 h-10 rounded-xl flex items-center justify-center transition-all <%= selectedBrand === 'all' ? 'text-tech-blue' : 'text-white/40' %>">
                            <i data-lucide="layout-grid" class="w-6 h-6"></i>
                        </div>
                        <span class="text-[10px] font-bold uppercase tracking-widest <%= selectedBrand === 'all' ? 'text-tech-blue' : 'text-white/40' %>">All Brands</span>
                        <% if (selectedBrand === 'all') { %>
                            <div class="absolute top-2 right-2 w-1.5 h-1.5 bg-tech-blue rounded-full"></div>
                        <% } %>
                    </a>

                    <!-- Brand Logos -->
                    <% brands.forEach(brand => { %>
                        <a href="/products?brand=<%= brand._id %>&category=<%= selectedCategory %>" 
                           class="group relative p-4 rounded-2xl transition-all duration-300 flex flex-col items-center justify-center gap-3 <%= selectedBrand === brand._id.toString() ? 'bg-tech-blue/20 border border-tech-blue/30' : 'bg-white/5 border border-white/5 hover:bg-white/10' %>">
                            <div class="w-10 h-10 flex items-center justify-center transition-all">
                                <img src="<%= brand.logo %>" alt="<%= brand.name %>" title="<%= brand.name %>" class="max-w-full max-h-full object-contain">
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-widest transition-colors text-center <%= selectedBrand === brand._id.toString() ? 'text-tech-blue' : 'text-white/40 group-hover:text-white/60' %>"><%= brand.name %></span>
                            <% if (selectedBrand === brand._id.toString()) { %>
                                <div class="absolute top-2 right-2 w-1.5 h-1.5 bg-tech-blue rounded-full"></div>
                            <% } %>
                        </a>
                    <% }) %>
                </div>
            </div>

            <!-- Category Filters -->
            <% if (selectedBrand !== 'all') { %>
                <div class="space-y-6 reveal">
                    <h3 class="text-sm font-bold uppercase tracking-widest text-white/40 flex items-center gap-2 px-2">
                        <i data-lucide="layers" class="w-4 h-4 text-tech-blue"></i> Category Classification
                    </h3>
                    <div class="flex flex-wrap items-center justify-center gap-3 p-2">
                        <a href="/products?brand=<%= selectedBrand %>&category=all" 
                           class="group relative px-8 py-3 rounded-full text-[10px] font-bold uppercase tracking-widest transition-all overflow-hidden <%= selectedCategory === 'all' ? 'text-white' : 'text-white/40 hover:text-white' %>">
                            <div class="absolute inset-0 <%= selectedCategory === 'all' ? 'bg-tech-blue' : 'bg-white/5 border border-white/10 hover:bg-white/10' %>"></div>
                            <span class="relative z-10">All Categories</span>
                        </a>
                        <% categories.forEach(category => { %>
                            <a href="/products?brand=<%= selectedBrand %>&category=<%= category._id %>" 
                               class="group relative px-8 py-3 rounded-full text-[10px] font-bold uppercase tracking-widest transition-all overflow-hidden <%= selectedCategory === category._id.toString() ? 'text-white' : 'text-white/40 hover:text-white' %>">
                                <div class="absolute inset-0 <%= selectedCategory === category._id.toString() ? 'bg-tech-blue' : 'bg-white/5 border border-white/10 hover:bg-white/10' %>"></div>
                                <span class="relative z-10"><%= category.name %></span>
                            </a>
                        <% }) %>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- Products Grid -->
        <% if (products && products.length > 0) { %>
            <div id="product-grid-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                <% products.forEach((product, index) => { %>
                    <div class="product-card-item group relative flex flex-col h-full reveal-product" 
                         data-name="<%= product.name.toLowerCase() %>"
                         style="transition-delay: <%= (index % 4) * 100 %>ms">
                        <!-- Advanced Card Glow -->
                        <div class="absolute -inset-1 bg-gradient-to-br from-tech-blue/30 via-tech-accent/20 to-purple-500/30 rounded-[2.5rem] blur-2xl opacity-0 group-hover:opacity-100 transition-all duration-700"></div>
                        
                        <!-- Main Card Container -->
                        <div class="relative flex flex-col h-full bg-white/2 border border-white/10 rounded-[2rem] overflow-hidden glass hover:border-tech-blue/40 transition-all duration-500 shadow-2xl">
                            <!-- Image Section with Dynamic Background -->
                            <div class="aspect-[16/11] relative overflow-hidden flex items-center justify-center p-4 bg-gradient-to-br from-white/5 via-tech-blue/5 to-transparent">
                                <!-- Animated Background Pattern (Subtle dots) -->
                                <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.2) 1px, transparent 0); background-size: 24px 24px;"></div>
                                
                                <img src="<%= product.image %>" alt="<%= product.name %>" class="relative z-10 max-w-[90%] max-h-[90%] object-contain transform group-hover:scale-105 transition-all duration-700 ease-[cubic-bezier(0.34,1.56,0.64,1)]">
                                
                                <!-- Brand Badge with Animation -->
                                <div class="absolute top-4 left-4 z-20">
                                    <div class="px-3 py-1 rounded-lg bg-tech-dark/80 backdrop-blur-xl border border-white/10 group-hover:border-tech-blue/50 group-hover:bg-tech-blue/10 transition-all duration-500">
                                        <span class="text-[9px] font-bold uppercase tracking-[0.2em] text-tech-blue group-hover:text-white transition-colors">
                                            <%= product.brand.name %>
                                        </span>
                                    </div>
                                </div>

                                <!-- Sophisticated Hover Content Reveal -->
                                <div class="absolute inset-0 bg-tech-dark/80 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col items-center justify-center p-6 text-center space-y-4 z-30">
                                    <div class="space-y-3 transform translate-y-6 group-hover:translate-y-0 transition-all duration-500 delay-75">
                                        <div class="w-10 h-0.5 h-tech-blue mx-auto rounded-full"></div>
                                        <p class="text-white/70 text-xs leading-relaxed line-clamp-3 font-medium italic">
                                            "<%= product.description %>"
                                        </p>
                                        <div class="flex flex-col gap-2">
                                            <a href="/contact?product=<%= encodeURIComponent(product.name) %>" 
                                               class="inline-flex items-center justify-center space-x-2 px-6 py-3 bg-tech-blue hover:bg-white hover:text-tech-dark text-white text-[9px] font-bold uppercase tracking-widest rounded-xl transition-all duration-300 shadow-lg shadow-tech-blue/30 active:scale-95">
                                                <span>Inquire Details</span>
                                                <i data-lucide="send" class="w-3.5 h-3.5"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Product Information Section -->
                            <div class="p-6 flex flex-col flex-grow space-y-4 bg-white/[0.02]">
                                <div class="space-y-2 flex-grow">
                                    <div class="flex items-center space-x-2">
                                        <span class="px-2 py-0.5 rounded bg-tech-blue/10 text-[8px] font-bold uppercase tracking-widest text-tech-blue">
                                            <%= product.category.name %>
                                        </span>
                                        <div class="flex-grow h-px bg-white/5"></div>
                                    </div>
                                    <h3 class="product-name text-lg md:text-xl font-bold font-grotesk text-white group-hover:text-tech-blue transition-colors leading-tight tracking-tight line-clamp-2">
                                        <%= product.name %>
                                    </h3>
                                </div>
                                
                                <div class="pt-4 border-t border-white/5 flex items-center justify-between">
                                    <span class="text-[8px] text-white/20 uppercase tracking-widest">ID: SS-<%= product._id.toString().slice(-4).toUpperCase() %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Dynamic No Results Message (Hidden by default, used for live search) -->
            <div id="live-no-results" class="hidden py-32 flex flex-col items-center justify-center space-y-8 glass-card rounded-[3rem] border-dashed border-white/10 relative overflow-hidden">
                <div class="absolute inset-0 bg-tech-blue/5 animate-pulse-slow"></div>
                <div class="relative w-24 h-24 rounded-3xl bg-white/5 flex items-center justify-center text-tech-blue/40 border border-white/10 glass">
                    <i data-lucide="search-x" class="w-12 h-12"></i>
                </div>
                <div class="relative text-center space-y-3">
                    <h3 class="text-3xl font-bold font-grotesk text-white">No Matching Products</h3>
                    <p class="text-white/40 max-w-md mx-auto">We couldn't find any products matching your search term in this category.</p>
                </div>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="py-32 flex flex-col items-center justify-center space-y-8 glass-card rounded-[3rem] border-dashed border-white/10 relative overflow-hidden reveal">
                <div class="absolute inset-0 bg-tech-blue/5 animate-pulse-slow"></div>
                <div class="relative w-24 h-24 rounded-3xl bg-white/5 flex items-center justify-center text-tech-blue/40 border border-white/10 glass">
                    <i data-lucide="package-search" class="w-12 h-12"></i>
                </div>
                <div class="relative text-center space-y-3">
                    <h3 class="text-3xl font-bold font-grotesk text-white">System Query: No Results</h3>
                    <p class="text-white/40 max-w-md mx-auto">Our database could not locate products matching your current filtration parameters. Please recalibrate your search.</p>
                </div>
                <a href="/products" class="relative px-10 py-4 bg-tech-blue hover:bg-tech-accent text-white font-bold rounded-2xl transition-all shadow-2xl shadow-tech-blue/40 hover:scale-105 active:scale-95 uppercase tracking-widest text-xs">
                    Reset System Filters
                </a>
            </div>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>

<script>
    // Initialize Lucide icons
    lucide.createIcons();

    // GSAP Scroll Reveal
    gsap.registerPlugin(ScrollTrigger);
    
    // Default reveal
    document.querySelectorAll('.reveal').forEach((el) => {
        gsap.from(el, {
            scrollTrigger: {
                trigger: el,
                start: "top 90%",
                toggleActions: "play none none none"
            },
            y: 30,
            opacity: 0,
            duration: 1,
            ease: "power3.out"
        });
    });

    // Product cards staggered reveal
    const productGrid = document.querySelector('.grid');
    if (productGrid) {
        gsap.from('.reveal-product', {
            scrollTrigger: {
                trigger: productGrid,
                start: "top 85%",
                toggleActions: "play none none none"
            },
            y: 50,
            opacity: 0,
            duration: 0.8,
            stagger: 0.1,
            ease: "power3.out"
        });
    }

    // Individual card hover micro-interactions
    document.querySelectorAll('.reveal-product').forEach(card => {
        const glow = card.querySelector('.bg-gradient-to-br');
        
        card.addEventListener('mouseenter', () => {
            gsap.to(glow, {
                opacity: 1,
                scale: 1.05,
                duration: 0.6,
                ease: "power2.out"
            });
        });
        
        card.addEventListener('mouseleave', () => {
            gsap.to(glow, {
                opacity: 0,
                scale: 1,
                duration: 0.6,
                ease: "power2.inOut"
            });
        });
    });

    // Client-side Fast Response Search
    const searchInput = document.querySelector('input[name="search"]');
    const productCards = document.querySelectorAll('.product-card-item');
    const productGridContainer = document.getElementById('product-grid-container');
    const liveNoResults = document.getElementById('live-no-results');

    if (searchInput) {
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase().trim();
            let visibleCount = 0;

            productCards.forEach(card => {
                const productName = card.getAttribute('data-name');
                if (productName.includes(searchTerm)) {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else {
                    card.classList.add('hidden');
                }
            });

            // Handle empty states
            if (visibleCount === 0) {
                if (productGridContainer) productGridContainer.classList.add('hidden');
                if (liveNoResults) liveNoResults.classList.remove('hidden');
            } else {
                if (productGridContainer) productGridContainer.classList.remove('hidden');
                if (liveNoResults) liveNoResults.classList.add('hidden');
            }

            // Refresh ScrollTrigger as heights might change
            ScrollTrigger.refresh();
        });

        // Prevent form submission to keep it instant
        searchInput.closest('form').addEventListener('submit', (e) => {
            e.preventDefault();
        });
    }
</script>
